// In-browser fiduciary engine — mirrors backend/app.py Layer 1–3 HTTP surface.
// Used when the app is opened as a single standalone .html file (no Python server).

const DB_KEY = "LEGACY_LEDGER_INLINE_ENGINE_V1";
const VERSION = "1.0.0-merged-L1-L7";
const COOLING_OFF_MS = 14 * 24 * 60 * 60 * 1000;
const CONSENSUS_THRESHOLD = 2.0;

const API_NATIVE = new Set(["google", "microsoft", "dropbox", "apple", "digilocker"]);
const BROWSER_AUTO = new Set(["netflix", "spotify", "jiohotstar", "gaana", "hulu", "adobe"]);

function LOAD_DB() {
  try {
    const RAW = localStorage.getItem(DB_KEY);
    if (RAW) return JSON.parse(RAW);
  } catch { /* noop */ }
  return { ASSETS: {}, CASES: {}, WORKFLOWS: {} };
}

function SAVE_DB(DB) {
  try {
    localStorage.setItem(DB_KEY, JSON.stringify(DB));
  } catch { /* quota */ }
}

function WF_ID() {
  return `wf_${Math.random().toString(16).slice(2, 14)}`;
}

function HASH() {
  return Array.from({ length: 64 }, () => Math.floor(Math.random() * 16).toString(16)).join("");
}

function ENSURE_CASE(DB, CASE_ID) {
  if (!DB.CASES[CASE_ID]) {
    DB.CASES[CASE_ID] = {
      case_id: CASE_ID,
      consensusscore: 0,
      stateregistryhit: false,
      attestationcount: 0,
      coolingoffstart: null,
      coolingoffend: null,
      ledgerblockhash: null,
    };
  }
  return DB.CASES[CASE_ID];
}

function VERIFICATION_OUT(ROW) {
  const NOW = Date.now();
  const READY =
    ROW.consensusscore >= CONSENSUS_THRESHOLD &&
    ROW.stateregistryhit &&
    ROW.attestationcount >= 1 &&
    ROW.coolingoffend &&
    NOW >= new Date(ROW.coolingoffend).getTime();
  return { ...ROW, ready_for_execution: READY };
}

function RECOMPUTE(DB, CASE_ID) {
  const ROW = ENSURE_CASE(DB, CASE_ID);
  ROW.consensusscore = (ROW.stateregistryhit ? 1 : 0) + ROW.attestationcount;
  if (
    ROW.consensusscore >= CONSENSUS_THRESHOLD &&
    ROW.stateregistryhit &&
    ROW.attestationcount >= 1 &&
    !ROW.coolingoffstart
  ) {
    ROW.coolingoffstart = new Date().toISOString();
    ROW.coolingoffend = new Date(Date.now() + COOLING_OFF_MS).toISOString();
  }
  ROW.ledgerblockhash = HASH();
  return VERIFICATION_OUT(ROW);
}

function CLASSIFY_TIER(PROVIDER) {
  const P = (PROVIDER || "").toLowerCase();
  if (API_NATIVE.has(P)) return "api_native";
  if (BROWSER_AUTO.has(P)) return "browser_automation";
  return "manual_packet";
}

function NEEDS_CHECKPOINT(ASSET, TIER) {
  if (TIER !== "api_native") return true;
  if ((ASSET.financial_value_monthly || 0) >= 50) return true;
  if (ASSET.dispositionintent === "transfer") return true;
  return false;
}

function SORT_ASSETS(DB) {
  const LIST = Object.values(DB.ASSETS);
  return LIST.sort((A, B) => {
    const CANCEL = (I) => (I === "cancel" || I === "delete" ? 0 : 1);
    const CA = CANCEL(A.dispositionintent);
    const CB = CANCEL(B.dispositionintent);
    if (CA !== CB) return CA - CB;
    return (B.financial_value_monthly || 0) - (A.financial_value_monthly || 0);
  });
}

function JSON_RESPONSE(DATA, STATUS = 200) {
  return { ok: STATUS >= 200 && STATUS < 300, status: STATUS, data: DATA };
}

function FAIL(MSG, STATUS = 409) {
  return JSON_RESPONSE({ detail: MSG }, STATUS);
}

export function dispatchEngineRequest(PATH, { METHOD = "GET", BODY } = {}) {
  const DB = LOAD_DB();
  const U = PATH.split("?")[0];
  const QS = new URLSearchParams(PATH.includes("?") ? PATH.split("?")[1] : "");

  // ---- health ----
  if (U === "/health" && METHOD === "GET") {
    return Promise.resolve(
      JSON_RESPONSE({
        status: "ok",
        layers: ["layer1", "layer2", "layer3", "layer4", "layer5", "layer6", "layer7"],
        version: VERSION,
      })
    );
  }

  // ---- layer1 ----
  if (U === "/layer1/assets" && METHOD === "POST") {
    const ID = BODY.assetid;
    if (DB.ASSETS[ID]) return Promise.resolve(FAIL("asset already enrolled", 409));
    DB.ASSETS[ID] = { ...BODY, graphdependencies: BODY.graphdependencies || [] };
    SAVE_DB(DB);
    return Promise.resolve(JSON_RESPONSE(DB.ASSETS[ID]));
  }

  if (U === "/layer1/assets" && METHOD === "GET") {
    return Promise.resolve(JSON_RESPONSE(Object.values(DB.ASSETS)));
  }

  if (U === "/layer1/graph/order" && METHOD === "GET") {
    return Promise.resolve(JSON_RESPONSE({ ordered_assetids: SORT_ASSETS(DB).map((A) => A.assetid) }));
  }

  // ---- layer2 ----
  if (U === "/layer2/registry-hit" && METHOD === "POST") {
    const ROW = ENSURE_CASE(DB, BODY.case_id);
    ROW.stateregistryhit = Boolean(BODY.death_certificate_id && String(BODY.death_certificate_id).toUpperCase().startsWith("DC-"));
    SAVE_DB(DB);
    return Promise.resolve(JSON_RESPONSE(RECOMPUTE(DB, BODY.case_id)));
  }

  if (U === "/layer2/attestation" && METHOD === "POST") {
    const ROW = ENSURE_CASE(DB, BODY.case_id);
    ROW.attestationcount += 1;
    SAVE_DB(DB);
    return Promise.resolve(JSON_RESPONSE(RECOMPUTE(DB, BODY.case_id)));
  }

  if (U === "/layer2/dead-man" && METHOD === "POST") {
    ENSURE_CASE(DB, BODY.case_id);
    SAVE_DB(DB);
    return Promise.resolve(JSON_RESPONSE(RECOMPUTE(DB, BODY.case_id)));
  }

  if (U.startsWith("/layer2/verification/") && METHOD === "GET") {
    const CASE_ID = decodeURIComponent(U.slice("/layer2/verification/".length));
    return Promise.resolve(JSON_RESPONSE(VERIFICATION_OUT(ENSURE_CASE(DB, CASE_ID))));
  }

  // ---- layer3 ----
  if (U === "/layer3/execute" && METHOD === "POST") {
    const CASE_ID = BODY.case_id;
    const ROW = ENSURE_CASE(DB, CASE_ID);
    if (ROW.consensusscore < CONSENSUS_THRESHOLD) return Promise.resolve(FAIL("consensusscore below threshold"));
    if (!ROW.stateregistryhit || ROW.attestationcount < 1) {
      return Promise.resolve(FAIL("Need registry hit + attestation"));
    }
    if (!BODY.force_skip_cooling_off && ROW.coolingoffend && Date.now() < new Date(ROW.coolingoffend).getTime()) {
      return Promise.resolve(FAIL(`cooling-off active until ${ROW.coolingoffend}`));
    }

    const ORDERED = SORT_ASSETS(DB);
    const OUT = [];
    ORDERED.forEach((ASSET, I) => {
      const KEY = `${CASE_ID}:${ASSET.assetid}:v1`;
      if (Object.values(DB.WORKFLOWS).some((W) => W.idempotencykey === KEY)) return;
      const TIER = CLASSIFY_TIER(ASSET.providername);
      const CHECKPOINT = NEEDS_CHECKPOINT(ASSET, TIER);
      const WF = {
        workflowid: WF_ID(),
        assetid: ASSET.assetid,
        case_id: CASE_ID,
        idempotencykey: KEY,
        executionstate: CHECKPOINT ? "pending_approval" : "executing",
        tierclassification: TIER,
        financialdrainrank: I + 1,
        Humancheckpointtriggered: CHECKPOINT,
        result_note: null,
      };
      DB.WORKFLOWS[WF.workflowid] = WF;
      OUT.push(WF);
    });
    SAVE_DB(DB);
    return Promise.resolve(JSON_RESPONSE(OUT));
  }

  if (U === "/layer3/checkpoint" && METHOD === "POST") {
    const WF = DB.WORKFLOWS[BODY.workflowid];
    if (!WF) return Promise.resolve(FAIL("workflow not found", 404));
    if (BODY.approved) WF.executionstate = "executing";
    else WF.result_note = "Rejected at human checkpoint";
    SAVE_DB(DB);
    return Promise.resolve(JSON_RESPONSE(WF));
  }

  if (U.startsWith("/layer3/advance/") && METHOD === "POST") {
    const ID = decodeURIComponent(U.slice("/layer3/advance/".length));
    const WF = DB.WORKFLOWS[ID];
    if (!WF) return Promise.resolve(FAIL("workflow not found", 404));
    if (WF.executionstate === "executing") WF.executionstate = "completed";
    SAVE_DB(DB);
    return Promise.resolve(JSON_RESPONSE(WF));
  }

  if (U === "/layer3/workflows" && METHOD === "GET") {
    const CASE_ID = QS.get("case_id");
    let LIST = Object.values(DB.WORKFLOWS);
    if (CASE_ID) LIST = LIST.filter((W) => W.case_id === CASE_ID);
    return Promise.resolve(JSON_RESPONSE(LIST));
  }

  return Promise.resolve(FAIL(`Unknown route: ${METHOD} ${PATH}`, 404));
}

