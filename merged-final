        </p>
      </div>

      <div className="graph-layout">
        <div className="graph-stage">
          <Canvas camera={{ position: [0, 2, 15], fov: 55 }} dpr={[1, 2]}>
            <color attach="background" args={["#070812"]} />
            <fog attach="fog" args={["#070812", 18, 40]} />
            <SceneContents
              ACTIVE_CATS={ACTIVE_CATS}
              SELECTED_ID={SELECTED_ID}
              ON_SELECT={SELECT_NODE}
              ON_HOVER={SET_HOVER_ID}
              NODES={ASSET_NODES}
              LOOKUP={LOOKUP}
              FOCUS_SET={FOCUS_SET}
            />
          </Canvas>

          <div className="graph-hud">
            <div className="filter-cluster">
              {Object.values(ASSET_CATEGORIES).map((CAT) => (
                <button
                  key={CAT.ID}
                  className={`filter-chip ${ACTIVE_CATS[CAT.ID] ? "on" : ""}`}
                  onClick={() => TOGGLE_CAT(CAT.ID)}
                >
                  <span className="dot" style={{ background: CAT.COLOR, display: "inline-block", marginRight: 6 }} />
                  {CAT.LABEL}
                </button>
              ))}
            </div>
            <div className="hud-tag">{VISIBLE_COUNT} / {ASSET_NODES.length} nodes</div>
          </div>

          <div className="graph-legend">
            {Object.values(ASSET_CATEGORIES).map((CAT) => (
              <div key={CAT.ID} style={{ display: "flex", alignItems: "center", gap: 8, fontSize: 12, color: "var(--TEXT-1)" }}>
                <span className="dot" style={{ background: CAT.COLOR }} />
                {CAT.LABEL}
              </div>
            ))}
          </div>
        </div>

        <motion.div
          className="panel panel-pad inspector"
          key={SELECTED_ID || "empty"}
          initial={{ opacity: 0, x: 16 }}
          animate={{ opacity: 1, x: 0 }}
          transition={{ duration: 0.35 }}
        >
          {SELECTED ? (
            <>
              <div>
                <span className="chip" style={{ borderColor: CATEGORY_COLOR(SELECTED.CATEGORY) }}>
                  <span className="dot" style={{ background: CATEGORY_COLOR(SELECTED.CATEGORY) }} />
                  {ASSET_CATEGORIES[SELECTED.CATEGORY].LABEL}
                </span>
                <div className="node-title" style={{ marginTop: 12 }}>{SELECTED.NAME}</div>
              </div>

              <div>
                <div className="node-kv"><span>Provider</span><span>{SELECTED.PROVIDER}</span></div>
                <div className="node-kv"><span>Value</span><span>{SELECTED.VALUE}</span></div>
                <div className="node-kv"><span>Node ID</span><span>{SELECTED.ID}</span></div>
                <div className="node-kv">
                  <span>Assigned intent</span>
                  <span style={{ color: SELECTED_INTENT ? "var(--TEAL)" : "var(--TEXT-2)" }}>
                    {SELECTED_INTENT ? INTENT_TYPES[SELECTED_INTENT].LABEL : "Unassigned"}
