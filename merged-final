import React, { useMemo, useRef, useState } from "react";
import { Canvas, useFrame } from "@react-three/fiber";
import { OrbitControls, Billboard, Text, Line } from "@react-three/drei";
import * as THREE from "three";
import { motion } from "framer-motion";
import { ASSET_EDGES, ASSET_CATEGORIES, INTENT_TYPES, CATEGORY_COLOR } from "../lib/data.js";
import { useEstate } from "../lib/store.jsx";
import { IconGraph, IconSpark } from "./Icons.jsx";

// ------------------------- SINGLE NODE -------------------------
function GraphNode({ NODE, ACTIVE, DIMMED, SELECTED, ON_SELECT, ON_HOVER }) {
  const MESH_REF = useRef();
  const GLOW_REF = useRef();
  const [HOVERED, SET_HOVERED] = useState(false);
  const COLOR = CATEGORY_COLOR(NODE.CATEGORY);
  const BASE_SIZE = NODE.IS_ROOT ? 0.55 : 0.28;

  useFrame((STATE) => {
    const T = STATE.clock.elapsedTime;
    const FLOAT = Math.sin(T * 1.2 + NODE.POSITION[0]) * 0.06;
    MESH_REF.current.position.y = NODE.POSITION[1] + FLOAT;
    GLOW_REF.current.position.y = NODE.POSITION[1] + FLOAT;
    const TARGET = SELECTED ? 1.6 : HOVERED ? 1.3 : 1;
    const S = THREE.MathUtils.lerp(MESH_REF.current.scale.x, TARGET, 0.15);
    MESH_REF.current.scale.setScalar(S);
    const GLOW_PULSE = (SELECTED ? 1.9 : 1.4) + Math.sin(T * 2 + NODE.POSITION[2]) * 0.15;
    GLOW_REF.current.scale.setScalar(GLOW_PULSE);
  });

  const OPACITY = DIMMED ? 0.12 : 1;

  return (
    <group>
      <mesh
        ref={MESH_REF}
        position={NODE.POSITION}
        onClick={(E) => {
          E.stopPropagation();
          ON_SELECT(NODE.ID);
        }}
        onPointerOver={(E) => {
          E.stopPropagation();
          SET_HOVERED(true);
          ON_HOVER(NODE.ID);
          document.body.style.cursor = "pointer";
        }}
        onPointerOut={() => {
          SET_HOVERED(false);
          ON_HOVER(null);
          document.body.style.cursor = "auto";
        }}
      >
        <sphereGeometry args={[BASE_SIZE, 32, 32]} />
        <meshStandardMaterial
          color={COLOR}
          emissive={COLOR}
          emissiveIntensity={SELECTED ? 2.4 : 1.2}
          roughness={0.3}
          metalness={0.1}
          transparent
          opacity={OPACITY}
        />
      </mesh>
      <mesh ref={GLOW_REF} position={NODE.POSITION} scale={1.5}>
        <sphereGeometry args={[BASE_SIZE, 16, 16]} />
        <meshBasicMaterial color={COLOR} transparent opacity={DIMMED ? 0.03 : 0.14} blending={THREE.AdditiveBlending} depthWrite={false} />
      </mesh>
      {(HOVERED || SELECTED || NODE.IS_ROOT) && !DIMMED && (
        <Billboard position={[NODE.POSITION[0], NODE.POSITION[1] + BASE_SIZE + 0.42, NODE.POSITION[2]]}>
          <Text fontSize={0.26} color="#eef1ff" anchorX="center" anchorY="middle" outlineWidth={0.012} outlineColor="#05060c">
            {NODE.NAME}
          </Text>
        </Billboard>
      )}
    </group>
  );
}

// ------------------------- EDGES -------------------------
function GraphEdges({ ACTIVE_CATS, LOOKUP }) {
  const REFS = useRef([]);
  useFrame((STATE) => {
    const T = STATE.clock.elapsedTime;
    REFS.current.forEach((M, I) => {
      if (M && M.material) M.material.opacity = 0.12 + Math.abs(Math.sin(T * 0.8 + I)) * 0.16;
    });
  });

  return (
    <group>
      {ASSET_EDGES.map((EDGE, I) => {
        const A = LOOKUP[EDGE.FROM];
        const B = LOOKUP[EDGE.TO];
        if (!A || !B) return null;
        const VISIBLE = ACTIVE_CATS[A.CATEGORY] && ACTIVE_CATS[B.CATEGORY];
        return (
          <Line
            key={`${EDGE.FROM}-${EDGE.TO}`}
            ref={(EL) => (REFS.current[I] = EL)}
            points={[A.POSITION, B.POSITION]}
            color={CATEGORY_COLOR(B.CATEGORY)}
            lineWidth={1.1}
            transparent
            opacity={VISIBLE ? 0.25 : 0.03}
          />
        );
      })}
    </group>
  );
}

function SceneContents({ ACTIVE_CATS, SELECTED_ID, ON_SELECT, ON_HOVER, NODES, LOOKUP, FOCUS_SET }) {
  return (
    <>
      <ambientLight intensity={0.7} />
      <pointLight position={[10, 10, 10]} intensity={1.2} />
      <pointLight position={[-10, -6, -8]} intensity={0.6} color="#7c6cff" />
      <GraphEdges ACTIVE_CATS={ACTIVE_CATS} LOOKUP={LOOKUP} />
      {NODES.map((NODE) => (
        <GraphNode
          key={NODE.ID}
          NODE={NODE}
          ACTIVE={ACTIVE_CATS[NODE.CATEGORY]}
          DIMMED={!ACTIVE_CATS[NODE.CATEGORY] || (FOCUS_SET && !FOCUS_SET.has(NODE.ID))}
          SELECTED={SELECTED_ID === NODE.ID}
          ON_SELECT={ON_SELECT}
          ON_HOVER={ON_HOVER}
        />
      ))}
      <OrbitControls enablePan={false} minDistance={6} maxDistance={26} autoRotate autoRotateSpeed={0.35} enableDamping dampingFactor={0.08} />
    </>
  );
}

export default function AssetGraphExplorer() {
  const { STORE, PUSH_TOAST } = useEstate();
