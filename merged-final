// ======================================================================
// LEGACY PACKET → PDF REPORT
// Builds a neat, multi-section estate execution report from the live store:
// death certificate, decedent details, beneficiary allocation, asset
// distribution directives, documents, execution summary, key custody and
// the immutable audit trail. Uses jsPDF + autoTable so it works both with
// the dev server and inside the single-file HTML build.
// ======================================================================

import { jsPDF } from "jspdf";
import autoTable from "jspdf-autotable";
import { INTENT_TYPES, LEGACY_PACKET } from "./data.js";

const NAVY = [15, 17, 32];
const VIOLET = [124, 108, 255];
const TEAL = [46, 168, 148];
const DARK = [24, 26, 40];
const MUTED = [110, 116, 140];
const HAIRLINE = [228, 230, 240];
const SOFT = [249, 250, 253];

const M = 14; // page margin (mm)

function sectionTitle(DOC, TEXT, Y) {
  DOC.setFillColor(...VIOLET);
  DOC.rect(M, Y - 3.6, 2.6, 5.2, "F");
  DOC.setFont("helvetica", "bold");
  DOC.setFontSize(12.5);
  DOC.setTextColor(...DARK);
  DOC.text(TEXT, M + 6, Y);
  return Y + 6;
}

function ensureSpace(DOC, Y, NEEDED, PAGE_H) {
  if (Y + NEEDED > PAGE_H - 16) {
    DOC.addPage();
    return 20;
  }
  return Y;
}

export function generateLegacyPacketPDF(STORE) {
  const DOC = new jsPDF({ unit: "mm", format: "a4" });
  const PAGE_W = DOC.internal.pageSize.getWidth();
  const PAGE_H = DOC.internal.pageSize.getHeight();
  const CW = PAGE_W - M * 2;

  const { PROFILE, BENEFICIARIES, ASSETS, INTENTS, DOCUMENTS, AUDIT, JOBS, SHARDS, ACTIVATION } = STORE;
  const DEATH = (ACTIVATION && ACTIVATION.DEATH_RECORD) || null;
  const IS_DECEASED = ACTIVATION && ACTIVATION.LIFE_STATUS === "DECEASED";

  // -------------------- Header band (page 1) --------------------
  DOC.setFillColor(...NAVY);
  DOC.rect(0, 0, PAGE_W, 34, "F");
  DOC.setFillColor(...VIOLET);
  DOC.circle(M + 3, 12, 3.2, "F");
  DOC.setTextColor(255, 255, 255);
  DOC.setFont("helvetica", "bold");
  DOC.setFontSize(16);
  DOC.text("LEGACY LEDGER CO.", M + 9, 13);
  DOC.setFont("helvetica", "normal");
  DOC.setFontSize(8.5);
  DOC.setTextColor(180, 185, 210);
  DOC.text("Digital Estate OS · Confidential Fiduciary Record", M + 9, 19);
  DOC.setFont("helvetica", "bold");
  DOC.setFontSize(12);
  DOC.setTextColor(120, 226, 205);
  DOC.text("Estate Execution & Legacy Report", M, 29);

  DOC.setFont("helvetica", "normal");
  DOC.setFontSize(8);
  DOC.setTextColor(180, 185, 210);
  DOC.text(`Packet ${LEGACY_PACKET.ID}`, PAGE_W - M, 12, { align: "right" });
  DOC.text(`Generated ${new Date().toLocaleString("en-GB")}`, PAGE_W - M, 17, { align: "right" });
  DOC.text(IS_DECEASED ? "Status: EXECUTED" : "Status: PREVIEW", PAGE_W - M, 22, { align: "right" });

  let Y = 44;

  // -------------------- Certificate of Death --------------------
  Y = sectionTitle(DOC, "Certificate of Death", Y);
  if (DEATH) {
    autoTable(DOC, {
      startY: Y,
      margin: { left: M, right: M },
      theme: "grid",
      styles: { fontSize: 9.5, cellPadding: 2.6, lineColor: HAIRLINE, textColor: DARK },
      columnStyles: {
        0: { cellWidth: 42, fontStyle: "bold", textColor: MUTED, fillColor: SOFT },
        2: { cellWidth: 42, fontStyle: "bold", textColor: MUTED, fillColor: SOFT },
      },
      body: [
        ["Decedent", PROFILE.FULL_NAME || "—", "Certificate no.", DEATH.CERTIFICATE_ID],
        ["Date of death", DEATH.DATE_OF_DEATH, "Manner", DEATH.MANNER || "Natural"],
        ["Cause of death", DEATH.CAUSE, "Place", DEATH.PLACE],
        ["Certified by", DEATH.CERTIFIED_BY, "Reported by", DEATH.REPORTED_BY],
      ],
    });
    Y = DOC.lastAutoTable.finalY + 8;

    const WITNESSES = DEATH.WITNESS_SIGNATURES || [];
    if (WITNESSES.length) {
      Y = ensureSpace(DOC, Y, 30, PAGE_H);
      Y = sectionTitle(DOC, "Witness E-Signatures (Death Verification)", Y);
      autoTable(DOC, {
        startY: Y,
        margin: { left: M, right: M },
        head: [["Contact", "Role", "Purpose", "Signed at"]],
        body: WITNESSES.map((W) => [W.NAME, W.ROLE, W.PURPOSE || "Death verification", W.SIGNED_AT || "—"]),
        theme: "grid",
        styles: { fontSize: 9, cellPadding: 2.4, lineColor: HAIRLINE, textColor: DARK },
        headStyles: { fillColor: VIOLET, textColor: 255, fontStyle: "bold" },
      });
      Y = DOC.lastAutoTable.finalY + 8;
    }
  } else {
    DOC.setFont("helvetica", "italic");
    DOC.setFontSize(9.5);
    DOC.setTextColor(...MUTED);
    DOC.text("No death has been reported — decedent currently marked living (preview report).", M, Y + 2);
    Y += 10;
  }

  // -------------------- Decedent / Estate --------------------
  Y = ensureSpace(DOC, Y, 40, PAGE_H);
  Y = sectionTitle(DOC, "Decedent & Estate Details", Y);
  autoTable(DOC, {
    startY: Y,
    margin: { left: M, right: M },
    theme: "grid",
    styles: { fontSize: 9.5, cellPadding: 2.6, lineColor: HAIRLINE, textColor: DARK },
    columnStyles: {
      0: { cellWidth: 42, fontStyle: "bold", textColor: MUTED, fillColor: SOFT },
      2: { cellWidth: 42, fontStyle: "bold", textColor: MUTED, fillColor: SOFT },
    },
    body: [
      ["Full legal name", PROFILE.FULL_NAME || "—", "Government ID", PROFILE.LEGAL_ID || "—"],
      ["Contact email", PROFILE.EMAIL || "—", "Jurisdiction", PROFILE.JURISDICTION || "—"],
      ["Beneficiaries", String(BENEFICIARIES.length), "Assets enrolled", String(ASSETS.filter((A) => !A.IS_ROOT).length)],
    ],
  });
  Y = DOC.lastAutoTable.finalY + 8;

  // -------------------- Beneficiaries & allocation --------------------
  Y = ensureSpace(DOC, Y, 30, PAGE_H);
  Y = sectionTitle(DOC, "Beneficiary Allocation", Y);
  const TOTAL_SHARE = BENEFICIARIES.reduce((S, B) => S + (B.SHARE || 0), 0);
  autoTable(DOC, {
    startY: Y,
    margin: { left: M, right: M },
    head: [["Beneficiary", "Relationship / Role", "Allocation"]],
    body: BENEFICIARIES.map((B) => [B.NAME, B.ROLE, `${B.SHARE}%`]),
    foot: [["Total", "", `${TOTAL_SHARE}%`]],
    theme: "grid",
    styles: { fontSize: 9.5, cellPadding: 2.6, lineColor: HAIRLINE, textColor: DARK },
    headStyles: { fillColor: VIOLET, textColor: 255, fontStyle: "bold" },
    footStyles: { fillColor: SOFT, textColor: DARK, fontStyle: "bold" },
    columnStyles: { 2: { halign: "right", cellWidth: 32 } },
  });
  Y = DOC.lastAutoTable.finalY + 8;

  // -------------------- Asset distribution directives --------------------
  Y = ensureSpace(DOC, Y, 30, PAGE_H);
  Y = sectionTitle(DOC, "Asset Distribution Directives", Y);
  const DIRECTIVES = ASSETS.filter((A) => !A.IS_ROOT).map((A) => {
    const IT = INTENTS[A.ID];
    const INTENT_LABEL = IT && IT.INTENT && INTENT_TYPES[IT.INTENT] ? INTENT_TYPES[IT.INTENT].LABEL : "Unassigned";
    const ROUTED = IT && IT.ROUTE_TO ? (BENEFICIARIES.find((B) => B.ID === IT.ROUTE_TO) || {}).NAME || "—" : "Estate default";
    return [A.NAME, A.PROVIDER || "—", A.VALUE || "—", INTENT_LABEL, ROUTED];
  });
  autoTable(DOC, {
    startY: Y,
    margin: { left: M, right: M },
    head: [["Asset", "Provider", "Value", "Disposition", "Routed to"]],
    body: DIRECTIVES.length ? DIRECTIVES : [["No assets enrolled", "", "", "", ""]],
    theme: "striped",
    styles: { fontSize: 9, cellPadding: 2.4, lineColor: HAIRLINE, textColor: DARK },
    headStyles: { fillColor: VIOLET, textColor: 255, fontStyle: "bold" },
    alternateRowStyles: { fillColor: SOFT },
  });
  Y = DOC.lastAutoTable.finalY + 8;

  // -------------------- Execution summary --------------------
  Y = ensureSpace(DOC, Y, 26, PAGE_H);
  Y = sectionTitle(DOC, "Execution Summary", Y);
  const COUNT_BY = (ID) => JOBS.filter((J) => J.STATE === ID).length;
  autoTable(DOC, {
    startY: Y,
    margin: { left: M, right: M },
    head: [["Completed", "Running", "Queued", "Needs review", "Failed", "Total directives"]],
    body: [[
      String(COUNT_BY("SUCCESS")),
      String(COUNT_BY("RUNNING")),
      String(COUNT_BY("QUEUED")),
      String(COUNT_BY("EXCEPTION")),
      String(COUNT_BY("FAILED")),
      String(JOBS.length),
    ]],
    theme: "grid",
    styles: { fontSize: 9.5, cellPadding: 2.6, halign: "center", lineColor: HAIRLINE, textColor: DARK },
    headStyles: { fillColor: TEAL, textColor: 255, fontStyle: "bold", halign: "center" },
  });
  Y = DOC.lastAutoTable.finalY + 8;

  // -------------------- Documents --------------------
  Y = ensureSpace(DOC, Y, 26, PAGE_H);
  Y = sectionTitle(DOC, "Legal Documents", Y);
  autoTable(DOC, {
    startY: Y,
    margin: { left: M, right: M },
    head: [["Document", "Status", "Notarized"]],
    body: DOCUMENTS.map((D) => [D.NAME, D.STATUS, D.NOTARIZED ? "Yes" : "No"]),
    theme: "grid",
    styles: { fontSize: 9.5, cellPadding: 2.4, lineColor: HAIRLINE, textColor: DARK },
    headStyles: { fillColor: VIOLET, textColor: 255, fontStyle: "bold" },
    columnStyles: { 1: { cellWidth: 40 }, 2: { cellWidth: 30, halign: "center" } },
  });
  Y = DOC.lastAutoTable.finalY + 8;

  // -------------------- Key custody --------------------
  Y = ensureSpace(DOC, Y, 26, PAGE_H);
  Y = sectionTitle(DOC, "Cryptographic Key Custody", Y);
  autoTable(DOC, {
    startY: Y,
    margin: { left: M, right: M },
    head: [["Shard holder", "Role", "Status"]],
    body: SHARDS.map((S) => [S.HOLDER, S.ROLE, S.RELEASED ? "Released" : "Withheld"]),
    theme: "grid",
    styles: { fontSize: 9.5, cellPadding: 2.4, lineColor: HAIRLINE, textColor: DARK },
    headStyles: { fillColor: VIOLET, textColor: 255, fontStyle: "bold" },
    columnStyles: { 2: { cellWidth: 34 } },
  });
  Y = DOC.lastAutoTable.finalY + 8;

  // -------------------- Audit trail --------------------
  Y = ensureSpace(DOC, Y, 26, PAGE_H);
  Y = sectionTitle(DOC, "Immutable Audit Trail", Y);
  autoTable(DOC, {
    startY: Y,
    margin: { left: M, right: M },
    head: [["#", "Timestamp", "Actor", "Action", "Target"]],
    body: AUDIT.map((E) => [String(E.SEQ), E.TIME, E.ACTOR, String(E.ACTION).replace(/_/g, " "), E.TARGET]),
    theme: "striped",
    styles: { fontSize: 8, cellPadding: 2, lineColor: HAIRLINE, textColor: DARK },
    headStyles: { fillColor: NAVY, textColor: 255, fontStyle: "bold" },
    alternateRowStyles: { fillColor: SOFT },
    columnStyles: { 0: { cellWidth: 10 }, 1: { cellWidth: 42 } },
  });

  // -------------------- Footers on every page --------------------
  const PAGES = DOC.internal.getNumberOfPages();
  for (let I = 1; I <= PAGES; I++) {
    DOC.setPage(I);
    DOC.setDrawColor(...HAIRLINE);
    DOC.line(M, PAGE_H - 12, PAGE_W - M, PAGE_H - 12);
    DOC.setFont("helvetica", "normal");
    DOC.setFontSize(7.5);
    DOC.setTextColor(...MUTED);
    DOC.text(`Integrity ${LEGACY_PACKET.CHECKSUM} · ${LEGACY_PACKET.CIPHER} / ${LEGACY_PACKET.KDF}`, M, PAGE_H - 7);
    DOC.text("Legacy Ledger Co. — Confidential", PAGE_W / 2, PAGE_H - 7, { align: "center" });
    DOC.text(`Page ${I} of ${PAGES}`, PAGE_W - M, PAGE_H - 7, { align: "right" });
  }

  const SAFE_NAME = (PROFILE.FULL_NAME || "estate").replace(/[^a-z0-9]+/gi, "-").replace(/^-|-$/g, "");
  DOC.save(`Legacy-Report-${SAFE_NAME}.pdf`);
}


