#!/usr/bin/env node
/**
 * Builds LegacyLedger.html — one self-contained HTML file.
 * Double-click to open the full frontend + in-browser backend engine.
 */

import { execSync } from "node:child_process";
import fs from "node:fs";
import path from "node:path";
import { fileURLToPath } from "node:url";

const __DIR = path.dirname(fileURLToPath(import.meta.url));
const ROOT = path.resolve(__DIR, "..");
const OUT_NAME = "LegacyLedger.html";
const DESKTOP = path.join(process.env.HOME || "", "Desktop", OUT_NAME);

function collectSources() {
  const PARTS = [];
  const walk = (DIR, EXT) => {
    for (const NAME of fs.readdirSync(DIR).sort()) {
      const FULL = path.join(DIR, NAME);
      if (fs.statSync(FULL).isDirectory()) {
        if (NAME === "node_modules" || NAME === ".venv") continue;
        walk(FULL, EXT);
      } else if (EXT.some((E) => NAME.endsWith(E))) {
        const REL = path.relative(ROOT, FULL);
        PARTS.push(`\n<!-- ========== ${REL} ========== -->\n${fs.readFileSync(FULL, "utf8")}`);
      }
    }
  };
  walk(path.join(ROOT, "src"), [".jsx", ".js", ".css"]);
  const BACKEND = path.join(ROOT, "backend", "app.py");
  if (fs.existsSync(BACKEND)) {
    PARTS.push(`\n<!-- ========== backend/app.py (Python fiduciary engine) ========== -->\n${fs.readFileSync(BACKEND, "utf8")}`);
  }
  return PARTS.join("\n");
}

console.log("Building single-file website…");
execSync("npm run build:single", {
  cwd: ROOT,
  stdio: "inherit",
  env: { ...process.env, VITE_SINGLE_FILE: "true" },
});

const BUILT = path.join(ROOT, "dist", "index.html");
if (!fs.existsSync(BUILT)) {
  console.error("Build failed — dist/index.html not found.");
  process.exit(1);
}

let HTML = fs.readFileSync(BUILT, "utf8");
const SOURCE_ARCHIVE = collectSources();

const HEADER = `<!--
  Legacy Ledger Co. · Living Enrollment
  Single-file build — frontend (React + Three.js) + backend engine (JS runtime + Python source archive)
  Open this file in any browser. No install, no server required.
-->
`;

const ARCHIVE_BLOCK = `
<!-- Full readable source archive (for review / submission). Hidden from UI. -->
<script type="text/plain" id="legacy-ledger-full-source" style="display:none">
${SOURCE_ARCHIVE.replace(/<\/script/gi, "<\\/script")}
</script>
`;

HTML = HEADER + HTML.replace("<html", '<html lang="en"');
if (HTML.includes("</body>")) {
  HTML = HTML.replace("</body>", `${ARCHIVE_BLOCK}\n</body>`);
} else {
  HTML += ARCHIVE_BLOCK;
}

const OUT_ROOT = path.join(ROOT, OUT_NAME);
fs.writeFileSync(OUT_ROOT, HTML);
fs.writeFileSync(DESKTOP, HTML);

const LINES = HTML.split("\n").length;
const MB = (Buffer.byteLength(HTML, "utf8") / (1024 * 1024)).toFixed(2);

console.log("");
console.log("Done!");
console.log(`  ${OUT_ROOT}`);
console.log(`  ${DESKTOP}`);
console.log(`  ${LINES.toLocaleString()} lines · ${MB} MB`);
console.log("");
console.log("Double-click LegacyLedger.html to open the full website.");


