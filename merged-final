// REAL PLAID LINK HOOK (activates automatically when a link_token is
// provided via VITE_PLAID_LINK_TOKEN). When no token is present we fall
// back to the guided mock flow below so the UX is always demonstrable.
// ------------------------------------------------------------------
function usePlaidBridge(ON_SUCCESS, ON_EXIT) {
  const LINK_TOKEN = import.meta.env.VITE_PLAID_LINK_TOKEN || null;

  const HANDLE_SUCCESS = useCallback(
    (PUBLIC_TOKEN, METADATA) => {
      // In production: POST PUBLIC_TOKEN to /api/plaid/exchange_public_token.
      const NAME = METADATA?.institution?.name || "Linked institution";
      ON_SUCCESS({ ID: `INS_${NAME.replace(/\s+/g, "_")}`, NAME });
    },
    [ON_SUCCESS]
  );

  const CONFIG = {
    token: LINK_TOKEN,
    onSuccess: HANDLE_SUCCESS,
    onExit: ON_EXIT,
  };

  const { open: OPEN_REAL, ready: READY_REAL } = usePlaidLink(CONFIG);
  return { LINK_TOKEN, OPEN_REAL, READY_REAL };
}

