const LOG_POOL = [
  { LEVEL: "DEBUG", MSG: "waitForSelector('#otp-input') · timeout 30s" },
  { LEVEL: "INFO", MSG: "screenshot captured → s3://legacyledger-evidence/JOB_ADOBE/step-04.png" },
  { LEVEL: "DEBUG", MSG: "evaluate(() => document.title) → 'Verify it's you'" },
  { LEVEL: "WARN", MSG: "network idle exceeded 2000ms · retrying navigation" },
  { LEVEL: "INFO", MSG: "proxy rotated → 49.36.x.x (residential-in-mumbai)" },
  { LEVEL: "DEBUG", MSG: "cookie jar persisted (14 cookies)" },
  { LEVEL: "ERROR", MSG: "TimeoutError: element [data-test=confirm] not interactable" },
  { LEVEL: "INFO", MSG: "human-in-loop token received · resuming step EXECUTE ACTION" },
  { LEVEL: "DEBUG", MSG: "type('••••••') into #otp-input ✓" },
  { LEVEL: "INFO", MSG: "POST /api/subscription/cancel → 200 OK" },
  { LEVEL: "WARN", MSG: "rate-limit header seen: x-ratelimit-remaining: 3" },
  { LEVEL: "INFO", MSG: "confirmation id captured: CAN-4821-ADBE ✓" },
];

const CURSOR_TRACK = [
  { x: "30%", y: "38%" },
  { x: "62%", y: "38%" },
  { x: "48%", y: "58%" },
  { x: "48%", y: "74%" },
  { x: "70%", y: "74%" },
];

function fmtTime(SECONDS) {
  const M = String(Math.floor(SECONDS / 60)).padStart(2, "0");
  const S = (SECONDS % 60).toFixed(3).padStart(6, "0");
  return `${M}:${S}`;
}

export default function HeadlessBrowserViewer() {
  const { PUSH_TOAST: ON_TOAST } = useEstate();
  const [LOGS, SET_LOGS] = useState(HEADLESS_LOG_SEED);
  const [CURSOR_IDX, SET_CURSOR_IDX] = useState(0);
  const [PAUSED, SET_PAUSED] = useState(false);
  const CLOCK_REF = useRef(6);
  const BODY_REF = useRef();

  useEffect(() => {
    if (PAUSED) return undefined;
    const TIMER = setInterval(() => {
      CLOCK_REF.current += 0.6 + Math.random() * 1.4;
      const PICK = LOG_POOL[Math.floor(Math.random() * LOG_POOL.length)];
      SET_LOGS((PREV) => {
        const NEXT = [...PREV, { T: fmtTime(CLOCK_REF.current), LEVEL: PICK.LEVEL, MSG: PICK.MSG }];
        return NEXT.slice(-120);
      });
      SET_CURSOR_IDX((I) => (I + 1) % CURSOR_TRACK.length);
    }, 1500);
    return () => clearInterval(TIMER);
  }, [PAUSED]);

  useEffect(() => {
    if (BODY_REF.current) BODY_REF.current.scrollTop = BODY_REF.current.scrollHeight;
  }, [LOGS]);

  const CURSOR = CURSOR_TRACK[CURSOR_IDX];
  const ERROR_COUNT = useMemo(() => LOGS.filter((L) => L.LEVEL === "ERROR").length, [LOGS]);

  return (
    <div className="view">
      <div className="view-head">
        <span className="eyebrow"><IconTerminal SIZE={14} /> Layer 3 · Execution Control</span>
        <h1 className="view-title">Headless Browser Stream & Logs</h1>
        <p className="view-desc">
          A live window into worker <code>chromium@121</code> as it drives <strong>Adobe · JOB_ADOBE</strong>.
          Every action is recorded for the audit trail; error logs surface here the instant something trips.
        </p>
      </div>

      <div className="headless-layout">
        <div className="browser-frame">
          <div className="browser-chrome">
            <div className="traffic">
              <span style={{ background: "#ff5f57" }} />
              <span style={{ background: "#febc2e" }} />
              <span style={{ background: "#28c840" }} />
            </div>
            <div className="omnibox">https://accounts.adobe.com/security/verify?flow=cancel</div>
            <span className="rec-pill"><span className="live-dot" /> REC</span>
          </div>

          <div className="browser-viewport">
            <div style={{ position: "absolute", inset: 0, padding: "34px 40px", opacity: 0.92 }}>
              <div style={{ fontSize: 20, fontWeight: 700, marginBottom: 6 }}>Verify it's you</div>
              <div style={{ fontSize: 13, color: "var(--TEXT-2)", marginBottom: 26 }}>
                Enter the 6-digit code we sent to •••• 4821
              </div>
              <div style={{ display: "flex", gap: 8, marginBottom: 24 }}>
                {[4, 8, 2, 1, "", ""].map((D, I) => (
                  <div key={I} style={{ width: 40, height: 50, borderRadius: 8, border: "1px solid var(--STROKE)", background: "rgba(6,8,18,0.6)", display: "grid", placeItems: "center", fontSize: 20, fontWeight: 700 }}>{D}</div>
                ))}
              </div>
              <div style={{ display: "flex", gap: 12 }}>
                <div className="btn btn-primary" style={{ pointerEvents: "none", padding: "10px 18px" }}>Verify</div>
                <div className="btn btn-ghost" style={{ pointerEvents: "none", padding: "10px 18px" }}>Resend</div>
              </div>
            </div>
            <motion.div className="cursor-ghost" animate={{ left: CURSOR.x, top: CURSOR.y }} transition={{ duration: 0.9 }} />
          </div>

          <div className="step-rail">
            {HEADLESS_STEPS.map((S) => (
              <div key={S.ID} className={`step-item ${S.ACTIVE ? "active" : ""}`}>
                <span className={`step-check ${S.DONE ? "done" : ""}`}>{S.DONE ? "✓" : S.ACTIVE ? "●" : ""}</span>
                {S.LABEL}
                {S.ACTIVE && <span className="live-pill" style={{ marginLeft: "auto" }}><span className="live-dot" /> in progress</span>}
              </div>
            ))}
          </div>
        </div>

        <div className="log-console">
          <div className="log-head">
            <IconTerminal SIZE={16} /> executor.log
            <span style={{ marginLeft: "auto", display: "flex", gap: 10, alignItems: "center" }}>
              <span style={{ color: "var(--ROSE)" }}>{ERROR_COUNT} errors</span>
              <button className="btn btn-ghost" style={{ padding: "5px 10px", fontSize: 12 }} onClick={() => SET_PAUSED((P) => !P)}>{PAUSED ? "Resume" : "Pause"}</button>
              <button className="btn btn-ghost" style={{ padding: "5px 10px", fontSize: 12 }} onClick={() => { SET_LOGS(HEADLESS_LOG_SEED); ON_TOAST("Log tail cleared"); }}>
