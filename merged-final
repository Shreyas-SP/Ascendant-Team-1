import React, { useMemo, useRef, useState } from "react";
import { Canvas, useFrame } from "@react-three/fiber";
import * as THREE from "three";
import { motion } from "framer-motion";
import { AUDIT_FORMATS, AUDIT_JURISDICTIONS } from "../lib/data.js";
import { useEstate, DOWNLOAD_FILE } from "../lib/store.jsx";
import { IconAudit, IconShield, IconDownload, IconCheck } from "./Icons.jsx";

// A rotating chain of hash-blocks with a pulse of light travelling the links.
function HashBlock({ POSITION, INDEX, COLOR }) {
  const REF = useRef();
  useFrame((STATE) => {
    const T = STATE.clock.elapsedTime;
    REF.current.rotation.x = T * 0.3 + INDEX;
    REF.current.rotation.y = T * 0.2 + INDEX;
    const NEAR = (Math.sin(T * 1.2 - INDEX * 0.6) + 1) / 2;
    REF.current.material.emissiveIntensity = 0.4 + NEAR * 1.4;
  });
  return (
    <mesh ref={REF} position={POSITION}>
      <boxGeometry args={[0.5, 0.5, 0.5]} />
      <meshStandardMaterial color={COLOR} emissive={COLOR} emissiveIntensity={0.6} metalness={0.3} roughness={0.35} wireframe={false} transparent opacity={0.92} />
    </mesh>
  );
}

function TravelPulse({ POINTS }) {
  const REF = useRef();
  const CURVE = useMemo(() => new THREE.CatmullRomCurve3(POINTS.map((P) => new THREE.Vector3(...P))), [POINTS]);
  useFrame((STATE) => {
    const T = (STATE.clock.elapsedTime * 0.25) % 1;
    const P = CURVE.getPoint(T);
    REF.current.position.copy(P);
  });
  return (
    <mesh ref={REF}>
      <sphereGeometry args={[0.12, 16, 16]} />
      <meshBasicMaterial color="#ffffff" transparent blending={THREE.AdditiveBlending} depthWrite={false} />
    </mesh>
  );
}

function ChainScene({ COLOR, BLOCKS }) {
  const POINTS = useMemo(() => {
    const N = Math.max(2, BLOCKS);
    const SPAN = 8.4;
    return Array.from({ length: N }).map((_, I) => [-4.2 + (I * SPAN) / Math.max(1, N - 1), Math.sin(I * 0.9) * 0.7, Math.cos(I * 0.7) * 0.5]);
  }, [BLOCKS]);
  const LINE_GEO = useMemo(() => {
    const G = new THREE.BufferGeometry();
    G.setAttribute("position", new THREE.Float32BufferAttribute(POINTS.flat(), 3));
    return G;
  }, [POINTS]);

  return (
    <>
      <ambientLight intensity={0.7} />
      <pointLight position={[0, 4, 6]} intensity={1.2} />
      <pointLight position={[-6, -3, -4]} intensity={0.5} color="#64e9d0" />
      <line geometry={LINE_GEO}>
        <lineBasicMaterial color={COLOR} transparent opacity={0.5} />
      </line>
      {POINTS.map((P, I) => (
        <HashBlock key={I} POSITION={P} INDEX={I} COLOR={COLOR} />
      ))}
      <TravelPulse POINTS={POINTS} />
    </>
  );
}

export default function AuditTrailFormatter() {
  const { STORE, PUSH_TOAST, APPEND_AUDIT } = useEstate();
