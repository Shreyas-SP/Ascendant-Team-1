  const SHELL_REF = useRef();
  const COUNT = 2600;

  const { TARGET, SCATTER } = useMemo(() => {
    const GEO = new THREE.IcosahedronGeometry(1.7, 5);
    const POS = GEO.attributes.position.array;
    const N = POS.length / 3;
    const TGT = new Float32Array(COUNT * 3);
    const SCT = new Float32Array(COUNT * 3);
    for (let I = 0; I < COUNT; I++) {
      const SRC = (I % N) * 3;
      TGT[I * 3] = POS[SRC];
      TGT[I * 3 + 1] = POS[SRC + 1];
      TGT[I * 3 + 2] = POS[SRC + 2];
      const R = 4 + Math.random() * 3;
      const TH = Math.random() * Math.PI * 2;
      const PH = Math.acos(2 * Math.random() - 1);
      SCT[I * 3] = R * Math.sin(PH) * Math.cos(TH);
      SCT[I * 3 + 1] = R * Math.sin(PH) * Math.sin(TH);
      SCT[I * 3 + 2] = R * Math.cos(PH);
    }
    return { TARGET: TGT, SCATTER: SCT };
  }, []);

  const POSITIONS = useMemo(() => SCATTER.slice(), [SCATTER]);
  const COLOR_A = useMemo(() => new THREE.Color("#7c6cff"), []);
  const COLOR_B = useMemo(() => new THREE.Color("#64e9d0"), []);

  useFrame((STATE, DELTA) => {
    const P = PROGRESS_REF.current;
    const ATTR = POINTS_REF.current.geometry.attributes.position;
    const ARR = ATTR.array;
    for (let I = 0; I < COUNT * 3; I++) {
      const TO = SCATTER[I] + (TARGET[I] - SCATTER[I]) * P;
      ARR[I] += (TO - ARR[I]) * 0.12;
    }
    ATTR.needsUpdate = true;

    POINTS_REF.current.rotation.y += DELTA * (0.15 + P * 0.35);
    POINTS_REF.current.rotation.x = Math.sin(STATE.clock.elapsedTime * 0.3) * 0.15;

    const MAT = POINTS_REF.current.material;
    MAT.color.copy(COLOR_A).lerp(COLOR_B, P);
    MAT.size = 0.028 + P * 0.02;

    SHELL_REF.current.rotation.y -= DELTA * 0.2;
    SHELL_REF.current.material.opacity = 0.05 + P * 0.25;
    const S = 1.7 * (0.9 + P * 0.15);
    SHELL_REF.current.scale.setScalar(S / 1.7);
  });

  return (
    <group>
      <points ref={POINTS_REF}>
        <bufferGeometry>
          <bufferAttribute attach="attributes-position" count={COUNT} array={POSITIONS} itemSize={3} />
        </bufferGeometry>
        <pointsMaterial size={0.03} sizeAttenuation transparent depthWrite={false} blending={THREE.AdditiveBlending} />
      </points>
      <mesh ref={SHELL_REF}>
        <icosahedronGeometry args={[1.7, 1]} />
        <meshBasicMaterial color="#7c6cff" wireframe transparent opacity={0.1} />
      </mesh>
    </group>
  );
}

function LockGlyph({ PROGRESS_REF }) {
  const REF = useRef();
  useFrame(() => {
    const P = PROGRESS_REF.current;
    REF.current.scale.setScalar(1 - P);
    REF.current.material.opacity = (1 - P) * 0.9;
  });
  return (
    <mesh ref={REF}>
      <sphereGeometry args={[0.35, 24, 24]} />
      <meshBasicMaterial color="#ffb86b" transparent opacity={0.9} />
    </mesh>
  );
}

