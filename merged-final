  --GREEN: #57e389;
  --SHADOW: 0 30px 80px -30px rgba(0, 0, 0, 0.85);
  --RADIUS: 20px;
  color-scheme: dark;
}

* {
  box-sizing: border-box;
}

html,
body,
#root {
  margin: 0;
  height: 100%;
  width: 100%;
}

body {
  background:
    radial-gradient(1200px 800px at 80% -10%, rgba(124, 108, 255, 0.16), transparent 60%),
    radial-gradient(1000px 700px at -10% 110%, rgba(100, 233, 208, 0.12), transparent 55%),
    var(--BG-0);
  color: var(--TEXT-0);
  font-family: "Inter", "Segoe UI", -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
  font-size: 15.5px;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

::selection {
  background: rgba(124, 108, 255, 0.4);
}

button {
  font-family: inherit;
  cursor: pointer;
}

/* ---------- APP LAYOUT ---------- */
.app-shell {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  display: grid;
  grid-template-columns: 264px 1fr;
}

.bg-canvas-holder {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
}

.bg-veil {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  background: radial-gradient(1100px 780px at 60% 40%, transparent 40%, rgba(5, 6, 12, 0.72) 100%);
}

/* ---------- NAV RAIL ---------- */
.nav-rail {
  position: sticky;
  top: 0;
  height: 100vh;
  padding: 26px 18px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  border-right: 1px solid var(--STROKE);
  background: linear-gradient(180deg, rgba(10, 12, 24, 0.72), rgba(6, 7, 15, 0.5));
  backdrop-filter: blur(18px);
  overflow-y: auto;
  overflow-x: hidden;
  overscroll-behavior: contain;
}

.brand {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 6px 10px 22px;
  flex-shrink: 0;
}

.brand-mark {
  width: 40px;
  height: 40px;
  border-radius: 12px;
  background: conic-gradient(from 140deg, var(--VIOLET), var(--TEAL), var(--VIOLET));
  box-shadow: 0 0 26px rgba(124, 108, 255, 0.55);
  position: relative;
  flex: none;
}
.brand-mark::after {
  content: "";
  position: absolute;
  inset: 9px;
  border-radius: 50%;
  background: var(--BG-0);
}
.brand-mark::before {
  content: "";
  position: absolute;
  inset: 16px;
  border-radius: 50%;
  background: var(--TEAL);
  box-shadow: 0 0 14px var(--TEAL);
  z-index: 2;
}

.brand-name {
  font-weight: 700;
  letter-spacing: 0.01em;
  font-size: 17px;
  line-height: 1.2;
}
.brand-sub {
  font-size: 11px;
  color: var(--TEXT-2);
  letter-spacing: 0.28em;
  text-transform: uppercase;
}

.nav-item {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 13px 14px;
  border-radius: 14px;
  border: 1px solid transparent;
  background: transparent;
  color: var(--TEXT-1);
  text-align: left;
  width: 100%;
  transition: all 0.18s ease;
  position: relative;
}
.nav-item:hover {
  color: var(--TEXT-0);
  background: rgba(124, 108, 255, 0.08);
}
.nav-item.active {
  color: var(--TEXT-0);
  background: linear-gradient(90deg, rgba(124, 108, 255, 0.22), rgba(124, 108, 255, 0.04));
  border-color: var(--STROKE-STRONG);
}
.nav-item.active::before {
  content: "";
  position: absolute;
  left: -18px;
  top: 12px;
  bottom: 12px;
  width: 3px;
  border-radius: 3px;
  background: linear-gradient(var(--VIOLET), var(--TEAL));
  box-shadow: 0 0 14px var(--VIOLET);
}
.nav-ico {
  width: 22px;
  height: 22px;
  flex: none;
  opacity: 0.9;
}
.nav-label {
  font-size: 14px;
  font-weight: 550;
}
.nav-step {
  margin-left: auto;
  font-size: 10px;
  color: var(--TEXT-2);
  font-variant-numeric: tabular-nums;
}

.nav-section {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-bottom: 14px;
  flex-shrink: 0;
}
.nav-section-label {
  font-size: 9.5px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--TEXT-2);
  padding: 6px 12px 4px;
  opacity: 0.75;
}
.nav-badge {
  margin-left: auto;
  min-width: 20px;
  height: 20px;
  padding: 0 6px;
  border-radius: 999px;
  background: var(--AMBER);
  color: #2a1a00;
  font-size: 11px;
  font-weight: 800;
  display: grid;
  place-items: center;
  box-shadow: 0 0 12px rgba(255, 184, 107, 0.6);
}

.nav-progress {
  margin-top: auto;
  padding: 16px 12px 6px;
  flex-shrink: 0;
}
.nav-progress-bar {
  height: 7px;
  border-radius: 7px;
  background: rgba(255, 255, 255, 0.06);
  overflow: hidden;
}
.nav-progress-fill {
  height: 100%;
  border-radius: 7px;
  background: linear-gradient(90deg, var(--VIOLET), var(--TEAL));
  box-shadow: 0 0 16px rgba(124, 108, 255, 0.6);
  transition: width 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
}
.nav-progress-label {
  display: flex;
  justify-content: space-between;
  font-size: 11px;
  color: var(--TEXT-2);
  margin-top: 8px;
}

/* ---------- MAIN VIEW ---------- */
.view {
  padding: 44px 58px 96px;
  max-width: 1280px;
  width: 100%;
  margin: 0 auto;
}

.view-head {
  margin-bottom: 30px;
}
.eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 9px;
  font-size: 11px;
  letter-spacing: 0.26em;
  text-transform: uppercase;
  color: var(--TEAL);
  background: rgba(100, 233, 208, 0.08);
  border: 1px solid rgba(100, 233, 208, 0.22);
  padding: 6px 12px;
  border-radius: 999px;
}
.view-title {
  font-size: 34px;
  font-weight: 750;
  margin: 16px 0 8px;
  letter-spacing: -0.02em;
}
.view-desc {
  color: var(--TEXT-1);
  max-width: 720px;
  line-height: 1.65;
  font-size: 16px;
}

/* ---------- PANEL / CARD ---------- */
.panel {
  background: var(--PANEL);
  border: 1px solid var(--STROKE);
  border-radius: var(--RADIUS);
  backdrop-filter: blur(20px);
  box-shadow: var(--SHADOW);
}
.panel-pad {
  padding: 30px;
}
.grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 22px;
}
.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
}
.section-title {
  font-size: 13px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--TEXT-2);
  margin: 0 0 16px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.section-title::before {
  content: "";
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--VIOLET);
  box-shadow: 0 0 10px var(--VIOLET);
}

/* ---------- FORM ELEMENTS ---------- */
.field {
  margin-bottom: 18px;
}
.field label {
  display: block;
  font-size: 13px;
  color: var(--TEXT-1);
  margin-bottom: 8px;
  letter-spacing: 0.02em;
}
.field .hint {
  color: var(--TEXT-2);
}
.input,
.select,
textarea.input {
  width: 100%;
  background: rgba(6, 8, 18, 0.7);
  border: 1px solid var(--STROKE);
  color: var(--TEXT-0);
  padding: 14px 16px;
  border-radius: 12px;
  font-size: 15px;
  outline: none;
  transition: border 0.16s, box-shadow 0.16s;
}
.input:focus,
.select:focus,
textarea.input:focus {
  border-color: var(--VIOLET);
  box-shadow: 0 0 0 3px rgba(124, 108, 255, 0.18);
}
textarea.input {
  resize: vertical;
  min-height: 92px;
  line-height: 1.5;
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 9px;
  padding: 14px 22px;
  border-radius: 12px;
  border: 1px solid var(--STROKE-STRONG);
  background: rgba(255, 255, 255, 0.04);
  color: var(--TEXT-0);
  font-size: 14.5px;
  font-weight: 600;
  transition: all 0.16s ease;
}
.btn:hover {
  background: rgba(255, 255, 255, 0.09);
  transform: translateY(-1px);
}
.btn-primary {
  background: linear-gradient(120deg, var(--VIOLET), var(--VIOLET-2));
  border-color: transparent;
  box-shadow: 0 12px 30px -10px rgba(124, 108, 255, 0.7);
}
.btn-primary:hover {
  box-shadow: 0 18px 40px -10px rgba(124, 108, 255, 0.9);
}
.btn-teal {
  background: linear-gradient(120deg, var(--TEAL), #4fd0c0);
  border-color: transparent;
  color: #04231f;
}
.btn-ghost {
  background: transparent;
}
.btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none;
}

.chip {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 7px 13px;
  border-radius: 999px;
  font-size: 13px;
  border: 1px solid var(--STROKE);
  background: rgba(255, 255, 255, 0.03);
  color: var(--TEXT-1);
}
.dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex: none;
}

/* ---------- PROFILE ---------- */
.profile-hero {
  display: grid;
  grid-template-columns: 260px 1fr;
  gap: 26px;
  align-items: stretch;
}
.avatar-stage {
  height: 260px;
  border-radius: var(--RADIUS);
  overflow: hidden;
  border: 1px solid var(--STROKE);
  background: radial-gradient(circle at 50% 30%, rgba(124, 108, 255, 0.2), transparent 70%), var(--BG-1);
  position: relative;
}
.identity-row {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-top: 6px;
}
.stat-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14px;
  margin-top: 20px;
}
.stat {
  padding: 16px;
  border-radius: 14px;
  border: 1px solid var(--STROKE);
  background: rgba(6, 8, 18, 0.4);
}
.stat-num {
  font-size: 26px;
  font-weight: 750;
  letter-spacing: -0.02em;
}
.stat-lbl {
  font-size: 12px;
  color: var(--TEXT-2);
  text-transform: uppercase;
  letter-spacing: 0.12em;
  margin-top: 4px;
}

/* ---- Estate readiness sphere overlay + checklist ---- */
.readiness-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}
.readiness-pct {
  font-size: 46px;
  font-weight: 780;
  letter-spacing: -0.04em;
  line-height: 1;
  text-shadow: 0 0 26px rgba(100, 233, 208, 0.35);
}
.readiness-pct span {
  font-size: 20px;
  font-weight: 650;
  opacity: 0.65;
  margin-left: 2px;
}
.readiness-lbl {
  margin-top: 6px;
  font-size: 10.5px;
  text-transform: uppercase;
  letter-spacing: 0.26em;
  color: var(--TEXT-2);
}

.readiness-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-top: 22px;
}
.readiness-tag {
  font-size: 11.5px;
  font-weight: 650;
  padding: 4px 11px;
  border-radius: 999px;
  border: 1px solid;
  white-space: nowrap;
  background: rgba(6, 8, 18, 0.35);
}
.milestone-list {
  margin-top: 14px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.milestone-row {
  display: grid;
  grid-template-columns: 24px 1fr auto;
  align-items: center;
  gap: 14px;
  padding: 12px 14px;
  border-radius: 12px;
  border: 1px solid var(--STROKE);
  background: rgba(6, 8, 18, 0.4);
}
.ms-check {
  width: 22px;
  height: 22px;
  border-radius: 999px;
  border: 1.5px solid;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #05060c;
  flex-shrink: 0;
}
.ms-meta {
  min-width: 0;
}
.ms-label {
  font-size: 14px;
  font-weight: 600;
  color: var(--TEXT-1);
}
.ms-bar {
  margin-top: 7px;
  height: 5px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.06);
  overflow: hidden;
}
.ms-bar span {
  display: block;
  height: 100%;
  border-radius: 999px;
  transition: width 0.5s ease;
}
.ms-detail {
  font-size: 13px;
  font-weight: 600;
  white-space: nowrap;
  font-variant-numeric: tabular-nums;
}

.beneficiary {
  display: flex;
  align-items: center;
  gap: 11px;
  padding: 13px;
  border-radius: 14px;
  border: 1px solid var(--STROKE);
  background: rgba(6, 8, 18, 0.4);
  margin-bottom: 12px;
}
.beneficiary .ba {
  width: 40px;
  height: 40px;
  border-radius: 12px;
  display: grid;
  place-items: center;
  font-weight: 700;
  color: #05060c;
  flex: none;
}
.beneficiary .bmeta {
  flex: 1;
  min-width: 0;
}
.beneficiary .bname {
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.beneficiary .brole {
  font-size: 13px;
  color: var(--TEXT-2);
}
.share-pill {
  font-variant-numeric: tabular-nums;
  font-weight: 700;
  color: var(--TEAL);
}

.share-input {
  display: inline-flex;
  align-items: center;
  gap: 1px;
  padding: 4px 8px;
  border-radius: 9px;
  border: 1px solid var(--STROKE);
  background: rgba(6, 8, 18, 0.5);
  flex: none;
  transition: border-color 0.15s ease, box-shadow 0.15s ease;
}
.share-input:focus-within {
  box-shadow: 0 0 0 3px rgba(124, 108, 255, 0.14);
}
.share-input input {
  width: 30px;
  border: none;
  background: transparent;
  outline: none;
  text-align: right;
  font-size: 14px;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
  padding: 0;
  -moz-appearance: textfield;
}
.share-input input::-webkit-outer-spin-button,
.share-input input::-webkit-inner-spin-button {
  -webkit-appearance: none;
  margin: 0;
}
.share-pct {
  font-size: 13px;
  font-weight: 700;
}

.row-x {
  width: 24px;
  height: 24px;
  flex: none;
  border-radius: 7px;
  border: 1px solid var(--STROKE);
  background: transparent;
  color: var(--TEXT-2);
  font-size: 16px;
  line-height: 1;
  cursor: pointer;
  transition: all 0.16s ease;
}
.row-x:hover {
  border-color: var(--ROSE);
  color: var(--ROSE);
  background: rgba(255, 117, 151, 0.1);
}

.add-beneficiary-form {
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding: 14px;
  margin-top: 4px;
  border-radius: 14px;
  border: 1px dashed var(--STROKE-STRONG);
  background: rgba(124, 108, 255, 0.06);
}

/* ---------- GRAPH EXPLORER ---------- */
.graph-layout {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 22px;
}
.graph-stage {
  height: 620px;
  border-radius: var(--RADIUS);
  overflow: hidden;
  border: 1px solid var(--STROKE);
  background: radial-gradient(circle at 50% 40%, rgba(20, 24, 54, 0.6), var(--BG-0) 80%);
  position: relative;
}
.graph-legend {
  position: absolute;
  left: 16px;
  bottom: 16px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 14px 16px;
  border-radius: 14px;
  background: rgba(6, 8, 18, 0.6);
  border: 1px solid var(--STROKE);
  backdrop-filter: blur(10px);
}
.graph-hud {
  position: absolute;
  top: 16px;
  left: 16px;
  right: 16px;
  display: flex;
  justify-content: space-between;
  gap: 12px;
  pointer-events: none;
}
.hud-tag {
  pointer-events: auto;
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--TEXT-1);
  background: rgba(6, 8, 18, 0.6);
  border: 1px solid var(--STROKE);
  padding: 8px 12px;
  border-radius: 10px;
  backdrop-filter: blur(8px);
}
.filter-cluster {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  pointer-events: auto;
}
.filter-chip {
  font-size: 13px;
  padding: 8px 14px;
  border-radius: 999px;
  border: 1px solid var(--STROKE);
  background: rgba(6, 8, 18, 0.6);
  color: var(--TEXT-1);
  backdrop-filter: blur(8px);
  transition: all 0.15s;
}
.filter-chip.on {
  color: var(--TEXT-0);
  border-color: var(--STROKE-STRONG);
  background: rgba(124, 108, 255, 0.22);
}

.inspector {
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.inspector-empty {
  color: var(--TEXT-2);
  font-size: 13px;
  line-height: 1.6;
  text-align: center;
  padding: 40px 10px;
}
.node-title {
  font-size: 20px;
  font-weight: 700;
}
.node-kv {
  display: flex;
  justify-content: space-between;
  padding: 10px 0;
  border-bottom: 1px dashed var(--STROKE);
  font-size: 13px;
}
.node-kv span:first-child {
  color: var(--TEXT-2);
}
.link-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.link-row {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 13px;
  color: var(--TEXT-1);
  padding: 8px 10px;
  border-radius: 10px;
  background: rgba(6, 8, 18, 0.4);
  border: 1px solid var(--STROKE);
}

/* ---------- INTENT MAPPING ---------- */
.intent-board {
  display: grid;
  grid-template-columns: 320px 1fr;
  gap: 22px;
}
.asset-queue {
  display: flex;
  flex-direction: column;
  gap: 10px;
  max-height: 640px;
  overflow-y: auto;
  padding-right: 6px;
}
.asset-card {
  padding: 14px;
  border-radius: 14px;
  border: 1px solid var(--STROKE);
  background: rgba(6, 8, 18, 0.5);
  transition: all 0.15s;
}
.asset-card:hover {
  border-color: var(--STROKE-STRONG);
}
.asset-card.selected {
  border-color: var(--VIOLET);
  box-shadow: 0 0 0 2px rgba(124, 108, 255, 0.28);
  background: rgba(124, 108, 255, 0.08);
}
.asset-card .ac-top {
  display: flex;
  align-items: center;
  gap: 10px;
}
.asset-card .ac-name {
  font-weight: 600;
  font-size: 14px;
}
.asset-card .ac-type {
  font-size: 12px;
  color: var(--TEXT-2);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}
.intent-tag {
  margin-left: auto;
  font-size: 12px;
  padding: 4px 10px;
  border-radius: 999px;
  font-weight: 600;
}

.intent-picker {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14px;
}
.intent-option {
  padding: 18px;
  border-radius: 16px;
  border: 1px solid var(--STROKE);
  background: rgba(6, 8, 18, 0.4);
  text-align: left;
  transition: all 0.16s;
  position: relative;
  overflow: hidden;
}
.intent-option:hover {
  transform: translateY(-2px);
  border-color: var(--STROKE-STRONG);
}
.intent-option.chosen {
  border-color: currentColor;
  box-shadow: 0 0 0 2px currentColor inset;
}
.intent-option .io-ico {
  width: 40px;
  height: 40px;
  border-radius: 12px;
  display: grid;
  place-items: center;
  margin-bottom: 12px;
}
.intent-option .io-name {
  font-weight: 700;
  font-size: 15px;
  color: var(--TEXT-0);
}
.intent-option .io-desc {
  font-size: 13px;
  color: var(--TEXT-2);
  margin-top: 6px;
  line-height: 1.5;
}

/* ---------- CONNECT / PLAID ---------- */
.connect-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18px;
}
.provider-card {
  padding: 22px;
  border-radius: 18px;
  border: 1px solid var(--STROKE);
  background: rgba(6, 8, 18, 0.45);
  display: flex;
  flex-direction: column;
  gap: 14px;
  transition: all 0.18s;
}
.provider-card:hover {
  transform: translateY(-3px);
  border-color: var(--STROKE-STRONG);
  box-shadow: var(--SHADOW);
}
.provider-top {
  display: flex;
  align-items: center;
  gap: 14px;
}
.provider-logo {
  width: 48px;
  height: 48px;
  border-radius: 14px;
  display: grid;
  place-items: center;
  font-weight: 800;
  font-size: 18px;
  flex: none;
}
.provider-name {
  font-weight: 700;
  font-size: 16px;
}
.provider-cat {
  font-size: 13px;
  color: var(--TEXT-2);
}
.provider-status {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  margin-top: auto;
}
.plaid-hero {
  display: flex;
  align-items: center;
  gap: 20px;
  padding: 24px;
  border-radius: 18px;
  background: linear-gradient(120deg, rgba(124, 108, 255, 0.16), rgba(100, 233, 208, 0.08));
  border: 1px solid var(--STROKE-STRONG);
  margin-bottom: 22px;
}
.plaid-mark {
  width: 60px;
  height: 60px;
  border-radius: 16px;
  background: #000;
  display: grid;
  place-items: center;
  flex: none;
  border: 1px solid var(--STROKE-STRONG);
}

/* ---------- MODAL (mock Plaid link) ---------- */
.modal-scrim {
  position: fixed;
  inset: 0;
  z-index: 50;
  background: rgba(4, 5, 12, 0.72);
  backdrop-filter: blur(6px);
  display: grid;
  place-items: center;
  padding: 24px;
}
.modal {
  width: 420px;
  max-width: 100%;
  border-radius: 22px;
  background: var(--PANEL-SOLID);
  border: 1px solid var(--STROKE-STRONG);
  box-shadow: var(--SHADOW);
  overflow: hidden;
}
.modal-head {
  padding: 20px 22px;
  border-bottom: 1px solid var(--STROKE);
  display: flex;
  align-items: center;
  gap: 12px;
}
.modal-body {
  padding: 22px;
}
.bank-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px;
  border-radius: 12px;
  border: 1px solid var(--STROKE);
  background: rgba(6, 8, 18, 0.4);
  margin-bottom: 10px;
  width: 100%;
  color: var(--TEXT-0);
  text-align: left;
  transition: all 0.15s;
}
.bank-row:hover {
  border-color: var(--VIOLET);
  background: rgba(124, 108, 255, 0.08);
}
.spinner {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  border: 3px solid rgba(255, 255, 255, 0.12);
  border-top-color: var(--VIOLET);
  animation: spin 0.8s linear infinite;
  margin: 20px auto;
}
@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.success-check {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: rgba(87, 227, 137, 0.14);
  border: 2px solid var(--GREEN);
  display: grid;
  place-items: center;
  margin: 10px auto 18px;
  color: var(--GREEN);
}

/* ---------- MISC ---------- */
.toast-stack {
  position: fixed;
  right: 24px;
  bottom: 24px;
  z-index: 80;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.toast {
  padding: 14px 18px;
  border-radius: 12px;
  background: var(--PANEL-SOLID);
  border: 1px solid var(--STROKE-STRONG);
  box-shadow: var(--SHADOW);
  font-size: 13px;
  display: flex;
  align-items: center;
  gap: 10px;
  min-width: 240px;
}

.scroll-slim::-webkit-scrollbar {
  width: 8px;
}
.scroll-slim::-webkit-scrollbar-thumb {
  background: rgba(140, 150, 220, 0.2);
  border-radius: 8px;
}

/* ---------- KPI STRIP ---------- */
.kpi-strip {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
  margin-bottom: 22px;
}
.kpi {
  padding: 18px;
  border-radius: 16px;
  border: 1px solid var(--STROKE);
  background: var(--PANEL);
  backdrop-filter: blur(16px);
  position: relative;
  overflow: hidden;
}
.kpi-num {
  font-size: 30px;
  font-weight: 780;
  letter-spacing: -0.03em;
  font-variant-numeric: tabular-nums;
}
.kpi-lbl {
  font-size: 12px;
  color: var(--TEXT-2);
  text-transform: uppercase;
  letter-spacing: 0.14em;
  margin-top: 4px;
}
.kpi-spark {
  position: absolute;
  right: -10px;
  bottom: -10px;
  opacity: 0.18;
}

/* ---------- WORKFLOW STREAM ---------- */
.workflow-layout {
  display: grid;
  grid-template-columns: 1fr 360px;
  gap: 22px;
}
.live-pill {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ROSE);
}
.live-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--ROSE);
  box-shadow: 0 0 0 0 rgba(255, 117, 151, 0.7);
  animation: pulse-ring 1.6s ease-out infinite;
}
@keyframes pulse-ring {
  0% { box-shadow: 0 0 0 0 rgba(255, 117, 151, 0.6); }
  100% { box-shadow: 0 0 0 10px rgba(255, 117, 151, 0); }
}
.job-row {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 6px 14px;
  padding: 15px 16px;
  border-radius: 14px;
  border: 1px solid var(--STROKE);
  background: rgba(6, 8, 18, 0.45);
  margin-bottom: 10px;
  transition: border 0.15s;
}
.job-row:hover { border-color: var(--STROKE-STRONG); }
.job-main { display: flex; align-items: center; gap: 12px; }
.job-name { font-weight: 600; font-size: 14px; }
.job-sub { font-size: 13px; color: var(--TEXT-2); }
.action-tag {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  padding: 4px 8px;
  border-radius: 6px;
  text-transform: uppercase;
}
.state-badge {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-size: 12px;
  font-weight: 600;
  padding: 6px 11px;
  border-radius: 999px;
  white-space: nowrap;
}
.job-progress {
  grid-column: 1 / -1;
  height: 6px;
  border-radius: 6px;
  background: rgba(255, 255, 255, 0.06);
  overflow: hidden;
}
.job-progress-fill {
  height: 100%;
  border-radius: 6px;
  transition: width 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
}
.job-stage-line {
  grid-column: 1 / -1;
  display: flex;
  gap: 6px;
  margin-top: 2px;
}
.stage-seg {
  flex: 1;
  height: 4px;
  border-radius: 4px;
  background: rgba(255, 255, 255, 0.07);
}

.pipeline-stage {
  height: 300px;
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid var(--STROKE);
  background: radial-gradient(circle at 50% 50%, rgba(20, 24, 54, 0.5), var(--BG-0) 85%);
  margin-bottom: 16px;
}

/* ---------- EXCEPTION DESK ---------- */
.exception-board {
  display: grid;
  grid-template-columns: 340px 1fr;
  gap: 22px;
}
.exc-card {
  padding: 16px;
  border-radius: 14px;
  border: 1px solid var(--STROKE);
  background: rgba(6, 8, 18, 0.5);
  margin-bottom: 12px;
  transition: all 0.15s;
  width: 100%;
  text-align: left;
}
.exc-card:hover { border-color: var(--STROKE-STRONG); }
.exc-card.selected { border-color: var(--AMBER); box-shadow: 0 0 0 2px rgba(255, 184, 107, 0.25); }
.exc-card.resolved { opacity: 0.5; }
.sev {
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.1em;
  padding: 3px 8px;
  border-radius: 6px;
  text-transform: uppercase;
}
.sev-HIGH { background: rgba(255, 117, 151, 0.16); color: var(--ROSE); }
.sev-MEDIUM { background: rgba(255, 184, 107, 0.16); color: var(--AMBER); }
.sev-LOW { background: rgba(100, 233, 208, 0.14); color: var(--TEAL); }
.resolve-stage {
  min-height: 480px;
  display: flex;
  flex-direction: column;
}
.otp-boxes { display: flex; gap: 10px; margin: 8px 0 4px; }
.otp-box {
  width: 48px;
  height: 56px;
  border-radius: 12px;
  border: 1px solid var(--STROKE);
  background: rgba(6, 8, 18, 0.7);
  color: var(--TEXT-0);
  text-align: center;
  font-size: 22px;
  font-weight: 700;
  outline: none;
}
.otp-box:focus { border-color: var(--VIOLET); box-shadow: 0 0 0 3px rgba(124, 108, 255, 0.18); }
.empty-desk {
  flex: 1;
  display: grid;
  place-items: center;
  text-align: center;
  color: var(--TEXT-2);
  gap: 10px;
}

/* ---------- HEADLESS VIEWER ---------- */
.headless-layout {
  display: grid;
  grid-template-columns: 1.35fr 1fr;
  gap: 22px;
}
.browser-frame {
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid var(--STROKE);
  background: #0b0e1c;
}
.browser-chrome {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 14px;
  background: rgba(255, 255, 255, 0.03);
  border-bottom: 1px solid var(--STROKE);
}
.traffic { display: flex; gap: 7px; }
.traffic span { width: 11px; height: 11px; border-radius: 50%; }
.omnibox {
  flex: 1;
  font-size: 12px;
  color: var(--TEXT-1);
  background: rgba(6, 8, 18, 0.7);
  border: 1px solid var(--STROKE);
  border-radius: 8px;
  padding: 7px 12px;
  font-family: "SF Mono", ui-monospace, Menlo, monospace;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.rec-pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  color: var(--ROSE);
  font-weight: 600;
}
.browser-viewport {
  height: 360px;
  position: relative;
  background: radial-gradient(circle at 50% 40%, rgba(20, 24, 54, 0.55), #060713 85%);
  overflow: hidden;
}
.cursor-ghost {
  position: absolute;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  border: 2px solid #fff;
  background: rgba(255, 255, 255, 0.25);
  pointer-events: none;
  transition: all 0.9s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 0 14px rgba(255, 255, 255, 0.5);
}
.step-rail {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 14px;
  border-top: 1px solid var(--STROKE);
}
.step-item {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 13px;
  padding: 8px 10px;
  border-radius: 10px;
  color: var(--TEXT-1);
}
.step-item.active { background: rgba(124, 108, 255, 0.12); color: var(--TEXT-0); }
.step-check {
  width: 18px;
  height: 18px;
  border-radius: 50%;
  border: 1.5px solid var(--STROKE-STRONG);
  display: grid;
  place-items: center;
  flex: none;
}
.step-check.done { background: var(--GREEN); border-color: var(--GREEN); color: #04231f; }

.log-console {
  border-radius: 16px;
  border: 1px solid var(--STROKE);
  background: #060713;
  display: flex;
  flex-direction: column;
  height: 100%;
  min-height: 520px;
  overflow: hidden;
}
.log-head {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 16px;
  border-bottom: 1px solid var(--STROKE);
  font-size: 12px;
  color: var(--TEXT-1);
  letter-spacing: 0.1em;
  text-transform: uppercase;
}
.log-body {
  flex: 1;
  overflow-y: auto;
  padding: 12px 16px;
  font-family: "SF Mono", ui-monospace, Menlo, monospace;
  font-size: 12.5px;
  line-height: 1.7;
}
.log-line { display: flex; gap: 12px; white-space: pre-wrap; }
.log-t { color: var(--TEXT-2); flex: none; }
.log-lvl { flex: none; width: 46px; font-weight: 700; }
.lvl-INFO { color: var(--TEAL); }
.lvl-DEBUG { color: var(--TEXT-2); }
.lvl-WARN { color: var(--AMBER); }
.lvl-ERROR { color: var(--ROSE); }
.log-msg { color: var(--TEXT-1); }

/* ---------- LEGACY PACKET PORTAL ---------- */
.packet-layout {
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: 22px;
}
.vault-stage {
  height: 420px;
  border-radius: 18px;
  overflow: hidden;
  border: 1px solid var(--STROKE);
  background: radial-gradient(circle at 50% 45%, rgba(30, 26, 66, 0.6), var(--BG-0) 80%);
  position: relative;
}
.vault-overlay {
  position: absolute;
  left: 20px;
  bottom: 20px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.packet-meta-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  margin-top: 18px;
}
.meta-cell {
  padding: 14px;
  border-radius: 12px;
  border: 1px solid var(--STROKE);
  background: rgba(6, 8, 18, 0.4);
}
.meta-cell .mv { font-weight: 700; font-size: 15px; font-variant-numeric: tabular-nums; }
.meta-cell .ml { font-size: 12px; color: var(--TEXT-2); text-transform: uppercase; letter-spacing: 0.1em; margin-top: 3px; }
.shard-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 14px;
  border-radius: 12px;
  border: 1px solid var(--STROKE);
  background: rgba(6, 8, 18, 0.4);
  margin-bottom: 8px;
}
.shard-key {
  width: 34px; height: 34px; border-radius: 9px; display: grid; place-items: center;
  color: #05060c; flex: none;
}
.content-chip {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 12px;
  border-radius: 10px;
  border: 1px solid var(--STROKE);
  background: rgba(6, 8, 18, 0.4);
  font-size: 13px;
}
.decrypt-bar {
  margin-top: 16px;
  height: 8px;
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.06);
  overflow: hidden;
}
.decrypt-fill {
  height: 100%;
  border-radius: 8px;
  background: linear-gradient(90deg, var(--VIOLET), var(--TEAL));
  box-shadow: 0 0 16px rgba(124, 108, 255, 0.6);
  transition: width 0.1s linear;
}

/* ---------- AUDIT TRAIL ---------- */
.audit-table { display: flex; flex-direction: column; }
.audit-row {
  display: grid;
  grid-template-columns: 44px 1.1fr 1.2fr 1.3fr 0.9fr;
  gap: 12px;
  align-items: center;
  padding: 11px 8px;
  border-bottom: 1px solid var(--STROKE);
  font-size: 13px;
}
.audit-row:last-child { border-bottom: none; }
.audit-head {
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--TEXT-2);
}

/* ---------- E-SIGNATURE ---------- */
.esign-layout {
  display: grid;
  grid-template-columns: 300px 1fr 300px;
  gap: 22px;
}
.sig-pad {
  position: relative;
  height: 130px;
  border-radius: 12px;
  border: 1px dashed var(--STROKE-STRONG);
  background: rgba(6, 8, 18, 0.6);
  overflow: hidden;
}
.sig-canvas { width: 100%; height: 100%; display: block; cursor: crosshair; touch-action: none; }
.sig-hint {
  position: absolute; inset: 0; display: grid; place-items: center;
  color: var(--TEXT-2); font-size: 14px; pointer-events: none;
}
.sig-baseline {
  position: absolute; left: 20px; right: 20px; bottom: 34px;
  border-bottom: 1.5px solid var(--STROKE); pointer-events: none;
}
.doc-sheet {
  border-radius: 12px;
  border: 1px solid var(--STROKE);
  background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.01));
  padding: 22px;
  position: relative;
  transition: box-shadow 0.4s;
}
.doc-sheet.sealed { box-shadow: inset 0 0 0 1px rgba(87,227,137,0.4); }
.doc-line { height: 8px; border-radius: 6px; background: rgba(255,255,255,0.08); margin-bottom: 10px; }
.notary-seal {
  width: 82px; height: 82px; border-radius: 50%; flex: none;
  border: 3px double var(--GREEN); color: var(--GREEN);
  display: grid; place-items: center; text-align: center;
  font-size: 10px; font-weight: 800; letter-spacing: 0.08em; line-height: 1.3;
  background: rgba(87,227,137,0.08);
}

/* ---------- WHITE-LABEL ---------- */
.whitelabel-layout {
  display: grid;
  grid-template-columns: 320px 1fr 300px;
  gap: 22px;
}
.wl-preview-head {
  display: flex; align-items: center; gap: 10px;
  padding: 12px 16px; border-bottom: 1px solid var(--STROKE);
  background: rgba(255,255,255,0.03);
}
.wl-preview-body { background: radial-gradient(circle at 50% 30%, rgba(20,24,54,0.5), #060713 90%); }
.wl-mini-nav {
  display: flex; align-items: center; gap: 18px;
  padding: 14px 18px; border-bottom: 1px solid var(--STROKE);
}
.wl-brand { display: flex; align-items: center; gap: 9px; margin-right: auto; }
.wl-logo {
  width: 28px; height: 28px; border-radius: 8px; color: #05060c;
  display: grid; place-items: center; font-weight: 800; font-size: 14px;
}
.wl-nav-item { font-size: 13px; padding-bottom: 3px; border-bottom: 2px solid transparent; }
.wl-btn {
  padding: 9px 16px; border-radius: 10px; font-size: 13px; font-weight: 600; color: #05060c;
}
.wl-btn.ghost { background: transparent !important; border: 1px solid; }

/* ---------- BILLING ---------- */
.cycle-toggle {
  display: inline-flex; padding: 5px; border-radius: 999px;
  border: 1px solid var(--STROKE); background: rgba(6,8,18,0.5);
}
.cycle-toggle button {
  border: none; background: transparent; color: var(--TEXT-1);
  padding: 9px 20px; border-radius: 999px; font-size: 14px; font-weight: 600;
  display: flex; align-items: center; gap: 8px;
}
.cycle-toggle button.on { background: var(--VIOLET); color: #fff; box-shadow: 0 6px 18px -6px var(--VIOLET); }
.save-pill { font-size: 11px; background: rgba(87,227,137,0.2); color: var(--GREEN); padding: 2px 7px; border-radius: 999px; }

.plan-card {
  position: relative; text-align: left; padding: 24px;
  border-radius: 18px; border: 1px solid var(--STROKE);
  background: var(--PANEL); backdrop-filter: blur(16px);
  display: flex; flex-direction: column; gap: 6px; transition: all 0.18s;
}
.plan-badge {
  position: absolute; top: -11px; left: 24px;
  background: var(--VIOLET); color: #fff; font-size: 11px; font-weight: 700;
  padding: 4px 12px; border-radius: 999px; box-shadow: 0 6px 18px -6px var(--VIOLET);
}
.plan-name { font-size: 18px; font-weight: 750; }
.plan-tag { font-size: 13px; color: var(--TEXT-2); }
.plan-price { font-size: 40px; font-weight: 800; letter-spacing: -0.03em; margin: 8px 0 12px; }
.plan-price .cur { font-size: 22px; vertical-align: super; margin-right: 2px; }
.plan-price .per { font-size: 15px; color: var(--TEXT-2); font-weight: 500; }
.plan-features { display: flex; flex-direction: column; gap: 9px; margin-bottom: 18px; }
.plan-feat { display: flex; align-items: center; gap: 9px; font-size: 13px; color: var(--TEXT-1); }
.plan-select {
  margin-top: auto; text-align: center; padding: 11px; border-radius: 11px;
  border: 1px solid; font-weight: 600; font-size: 14px;
}

.credit-card {
  border-radius: 16px; padding: 22px; color: #fff;
  display: flex; flex-direction: column; gap: 22px; min-height: 190px;
  box-shadow: var(--SHADOW); transition: all 0.4s;
}
.credit-card.paid { filter: saturate(1.2); }
.cc-chip {
  width: 42px; height: 32px; border-radius: 7px;
  background: linear-gradient(135deg, #f4d47c, #b8922f);
}
.cc-number { font-size: 21px; letter-spacing: 0.06em; font-family: "SF Mono", ui-monospace, Menlo, monospace; }

@media (max-width: 1080px) {
  .kpi-strip { grid-template-columns: repeat(2, 1fr); }
  .workflow-layout,
  .exception-board,
  .headless-layout,
  .packet-layout,
  .esign-layout,
  .whitelabel-layout {
    grid-template-columns: 1fr;
  }
  .grid-3 { grid-template-columns: 1fr; }
}

@media (max-width: 1080px) {
  .app-shell {
    grid-template-columns: 1fr;
  }
  .nav-rail {
    position: relative;
    height: auto;
    flex-direction: row;
    overflow-x: auto;
  }
  .nav-progress {
    display: none;
  }
  .graph-layout,
  .intent-board,
  .profile-hero,
  .grid-2,
  .connect-grid,
  .intent-picker {
    grid-template-columns: 1fr;
  }
}

/* ==================== LIVE ENGINE ==================== */
.engine-status {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 7px 12px;
  margin: 14px 0 4px;
  border-radius: 10px;
  border: 1px solid var(--STROKE);
  background: rgba(6, 8, 18, 0.5);
  font-size: 12px;
  font-weight: 600;
  flex-shrink: 0;
}
.engine-dot {
  width: 8px;
  height: 8px;
  border-radius: 999px;
  flex: none;
}
.engine-status.online .engine-dot {
  background: var(--GREEN);
  box-shadow: 0 0 10px var(--GREEN);
  animation: engine-pulse 1.8s ease-in-out infinite;
}
.engine-status.offline .engine-dot {
  background: #ff7597;
}
.engine-status.online .engine-txt {
  color: var(--GREEN);
}
.engine-status.offline .engine-txt {
  color: var(--TEXT-2);
}
@keyframes engine-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.35; }
}

.engine-empty {
  padding: 18px;
  border-radius: 12px;
  border: 1px dashed var(--STROKE);
  background: rgba(6, 8, 18, 0.4);
  color: var(--TEXT-2);
  font-size: 13.5px;
  line-height: 1.6;
}
.engine-empty code,
.view-desc code {
  font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
