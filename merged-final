import React, { useMemo, useRef } from "react";
import { Canvas, useFrame } from "@react-three/fiber";
import * as THREE from "three";

// ------------------------------------------------------------------
// THEME: "The Eternal Flame & the Tree of Life."
// A warm flame burns at the base — the light of a life. From it,
// embers (a person's memories, documents, moments) rise, cooling
// from amber into eternal violet-teal starlight, and settle into a
// luminous Tree of Life above that outlives them. Warm life flowing
// upward into cool, preserved legacy — the whole premise of Legacy Ledger Co.
// ------------------------------------------------------------------

const EMBER_COUNT = 780;
const TREE_STARS = 300;

const BOTTOM_Y = -9;
const TOP_Y = 9;
const SPAN_Y = TOP_Y - BOTTOM_Y;

// Warm → cool palette (life → eternity).
const C_FLAME = new THREE.Color("#ff8a3d");
const C_MID = new THREE.Color("#ff7597");
const C_COOL = new THREE.Color("#7c6cff");
const C_ETERNAL = new THREE.Color("#64e9d0");

function EmberStream() {
  const POINTS_REF = useRef();

  const STATE = useMemo(() => {
    const POSITIONS = new Float32Array(EMBER_COUNT * 3);
    const COLORS = new Float32Array(EMBER_COUNT * 3);
    const BASE_X = new Float32Array(EMBER_COUNT);
    const BASE_Z = new Float32Array(EMBER_COUNT);
    const SPEED = new Float32Array(EMBER_COUNT);
    const SWAY_AMP = new Float32Array(EMBER_COUNT);
    const SWAY_FREQ = new Float32Array(EMBER_COUNT);
    const SWAY_PHASE = new Float32Array(EMBER_COUNT);

    const SEED = (I) => {
      // Flame base is a narrow disk; sparks widen as they rise.
      const A = Math.random() * Math.PI * 2;
      const R = Math.pow(Math.random(), 0.6) * 2.2;
      BASE_X[I] = Math.cos(A) * R;
      BASE_Z[I] = Math.sin(A) * R * 0.8 - 1.2;
      SPEED[I] = 0.5 + Math.random() * 0.9;
      SWAY_AMP[I] = 0.3 + Math.random() * 1.6;
      SWAY_FREQ[I] = 0.2 + Math.random() * 0.6;
      SWAY_PHASE[I] = Math.random() * Math.PI * 2;
    };

    for (let I = 0; I < EMBER_COUNT; I++) {
      SEED(I);
      // Stagger initial heights so the stream is full immediately.
      POSITIONS[I * 3] = BASE_X[I];
      POSITIONS[I * 3 + 1] = BOTTOM_Y + Math.random() * SPAN_Y;
      POSITIONS[I * 3 + 2] = BASE_Z[I];
    }
    return { POSITIONS, COLORS, BASE_X, BASE_Z, SPEED, SWAY_AMP, SWAY_FREQ, SWAY_PHASE, SEED };
  }, []);

  const TMP = useMemo(() => new THREE.Color(), []);

  useFrame((FRAME, DELTA) => {
    const T = FRAME.clock.elapsedTime;
    const DT = Math.min(DELTA, 0.05);
    const P = POINTS_REF.current.geometry.attributes.position;
    const C = POINTS_REF.current.geometry.attributes.color;
    const PA = P.array;
    const CA = C.array;

    for (let I = 0; I < EMBER_COUNT; I++) {
      let Y = PA[I * 3 + 1] + STATE.SPEED[I] * DT;
      if (Y > TOP_Y) {
        STATE.SEED(I);
        Y = BOTTOM_Y - Math.random() * 1.5;
      }
      const HN = (Y - BOTTOM_Y) / SPAN_Y; // 0 at flame, 1 at canopy
      const WIDEN = 0.35 + HN * 2.4;
      const SWAY = Math.sin(T * STATE.SWAY_FREQ[I] + STATE.SWAY_PHASE[I]);
      PA[I * 3] = STATE.BASE_X[I] + SWAY * STATE.SWAY_AMP[I] * WIDEN;
      PA[I * 3 + 1] = Y;
      PA[I * 3 + 2] = STATE.BASE_Z[I] + Math.cos(T * STATE.SWAY_FREQ[I] + STATE.SWAY_PHASE[I]) * STATE.SWAY_AMP[I] * WIDEN * 0.5;

      // Colour transmutes warm → cool as the ember ascends.
      if (HN < 0.35) TMP.copy(C_FLAME).lerp(C_MID, HN / 0.35);
      else if (HN < 0.7) TMP.copy(C_MID).lerp(C_COOL, (HN - 0.35) / 0.35);
      else TMP.copy(C_COOL).lerp(C_ETERNAL, (HN - 0.7) / 0.3);

      // Fade in at the flame, fade out into the canopy (baked into
      // rgb because additive blending reads brightness as opacity).
      let ALPHA = 1;
      if (HN < 0.08) ALPHA = HN / 0.08;
      else if (HN > 0.7) ALPHA = Math.max(0, 1 - (HN - 0.7) / 0.3) * 0.9 + 0.1;
      const FLICKER = 0.8 + 0.2 * Math.sin(T * 6 + STATE.SWAY_PHASE[I] * 3);
      ALPHA *= FLICKER;

      CA[I * 3] = TMP.r * ALPHA;
      CA[I * 3 + 1] = TMP.g * ALPHA;
      CA[I * 3 + 2] = TMP.b * ALPHA;
    }
    P.needsUpdate = true;
    C.needsUpdate = true;
  });

  return (
    <points ref={POINTS_REF}>
      <bufferGeometry>
        <bufferAttribute attach="attributes-position" count={EMBER_COUNT} array={STATE.POSITIONS} itemSize={3} />
        <bufferAttribute attach="attributes-color" count={EMBER_COUNT} array={STATE.COLORS} itemSize={3} />
      </bufferGeometry>
      <pointsMaterial size={0.085} vertexColors transparent opacity={0.95} sizeAttenuation depthWrite={false} blending={THREE.AdditiveBlending} />
    </points>
  );
}

// A luminous Tree of Life the embers rise into: trunk + canopy of
// stars, wired with faint branch-lines. Represents the enduring
// legacy that memories are preserved within.
function buildTree() {
  const POS = new Float32Array(TREE_STARS * 3);
  const COL = new Float32Array(TREE_STARS * 3);
  const GOLDEN = Math.PI * (1 + Math.sqrt(5));
  const TRUNK = Math.floor(TREE_STARS * 0.16);
  const LEAF = new THREE.Color("#8ea2ff");
  const TIP = new THREE.Color("#64e9d0");

  for (let I = 0; I < TREE_STARS; I++) {
    if (I < TRUNK) {
      const TY = (I / TRUNK) * 3.2 + 1.4;
      POS[I * 3] = Math.cos(I * 2.1) * 0.22 * (1 - I / TRUNK) + Math.sin(I) * 0.1;
      POS[I * 3 + 1] = TY;
      POS[I * 3 + 2] = Math.sin(I * 2.1) * 0.22 * (1 - I / TRUNK) - 1.6;
    } else {
      const J = I - TRUNK;
      const JT = J / (TREE_STARS - TRUNK);
      const PHI = Math.acos(1 - 2 * JT);
      const THETA = GOLDEN * J;
      const R = 3.4 * Math.cbrt(Math.abs(Math.sin(J * 51.31)));
      POS[I * 3] = R * Math.sin(PHI) * Math.cos(THETA);
      POS[I * 3 + 1] = R * Math.cos(PHI) * 0.9 + 5.6;
      POS[I * 3 + 2] = R * Math.sin(PHI) * Math.sin(THETA) - 1.6;
    }
    const M = I / TREE_STARS;
    const C = LEAF.clone().lerp(TIP, M);
    COL[I * 3] = C.r;
    COL[I * 3 + 1] = C.g;
    COL[I * 3 + 2] = C.b;
  }
  return { POS, COL };
}

function buildBranchLines(POS) {
  const PAIRS = [];
  const SET = new Set();
  for (let I = 0; I < TREE_STARS; I++) {
    let B1 = -1;
    let D1 = Infinity;
    for (let J = 0; J < TREE_STARS; J++) {
      if (J === I) continue;
      const DX = POS[J * 3] - POS[I * 3];
      const DY = POS[J * 3 + 1] - POS[I * 3 + 1];
      const DZ = POS[J * 3 + 2] - POS[I * 3 + 2];
      const D = DX * DX + DY * DY + DZ * DZ;
      if (D < D1) { D1 = D; B1 = J; }
    }
    if (B1 >= 0) {
      const KEY = I < B1 ? `${I}_${B1}` : `${B1}_${I}`;
      SET.add(KEY);
    }
  }
  SET.forEach((K) => {
    const [A, B] = K.split("_").map(Number);
    PAIRS.push(POS[A * 3], POS[A * 3 + 1], POS[A * 3 + 2], POS[B * 3], POS[B * 3 + 1], POS[B * 3 + 2]);
  });
  return new Float32Array(PAIRS);
}

function TreeOfLife() {
  const GROUP_REF = useRef();
  const { POS, COL } = useMemo(() => buildTree(), []);
  const LINES = useMemo(() => buildBranchLines(POS), [POS]);

  useFrame((FRAME) => {
    const T = FRAME.clock.elapsedTime;
    GROUP_REF.current.rotation.y = Math.sin(T * 0.06) * 0.35;
    GROUP_REF.current.position.y = Math.sin(T * 0.25) * 0.12;
  });

  return (
    <group ref={GROUP_REF}>
      <points>
        <bufferGeometry>
          <bufferAttribute attach="attributes-position" count={TREE_STARS} array={POS} itemSize={3} />
          <bufferAttribute attach="attributes-color" count={TREE_STARS} array={COL} itemSize={3} />
        </bufferGeometry>
        <pointsMaterial size={0.06} vertexColors transparent opacity={0.72} sizeAttenuation depthWrite={false} blending={THREE.AdditiveBlending} />
      </points>
      <lineSegments>
        <bufferGeometry>
          <bufferAttribute attach="attributes-position" count={LINES.length / 3} array={LINES} itemSize={3} />
        </bufferGeometry>
        <lineBasicMaterial color="#5b6bd6" transparent opacity={0.16} depthWrite={false} blending={THREE.AdditiveBlending} />
      </lineSegments>
    </group>
  );
}

// The flame itself — a warm, gently breathing glow at the base.
function FlameGlow() {
  const CORE_REF = useRef();
  const HALO_REF = useRef();
  useFrame((FRAME) => {
    const T = FRAME.clock.elapsedTime;
    const FLICKER = 1 + Math.sin(T * 9) * 0.06 + Math.sin(T * 23) * 0.03;
    CORE_REF.current.scale.setScalar(FLICKER);
    HALO_REF.current.scale.setScalar(1 + Math.sin(T * 2.2) * 0.12);
    CORE_REF.current.material.opacity = 0.28 * FLICKER;
  });
  return (
    <group position={[0, -8, -1.2]}>
      <mesh ref={HALO_REF}>
        <sphereGeometry args={[3.8, 32, 32]} />
        <meshBasicMaterial color="#ff7a2f" transparent opacity={0.06} depthWrite={false} blending={THREE.AdditiveBlending} />
      </mesh>
      <mesh ref={CORE_REF}>
        <sphereGeometry args={[1.5, 32, 32]} />
        <meshBasicMaterial color="#ffb457" transparent opacity={0.28} depthWrite={false} blending={THREE.AdditiveBlending} />
      </mesh>
    </group>
  );
}

// A cool halo near the canopy — eternity receiving the light.
function CanopyGlow() {
  const REF = useRef();
  useFrame((FRAME) => {
    const T = FRAME.clock.elapsedTime;
    REF.current.material.opacity = 0.05 + Math.abs(Math.sin(T * 0.5)) * 0.03;
  });
  return (
    <mesh ref={REF} position={[0, 6, -2]}>
      <sphereGeometry args={[4.4, 32, 32]} />
      <meshBasicMaterial color="#6c7cff" transparent opacity={0.06} depthWrite={false} blending={THREE.AdditiveBlending} />
    </mesh>
  );
}

export default function Background3D() {
  return (
    <div className="bg-canvas-holder">
      <Canvas camera={{ position: [0, 0, 17], fov: 60 }} dpr={[1, 2]} gl={{ antialias: true, alpha: true }}>
        <fog attach="fog" args={["#05060c", 16, 34]} />
        <FlameGlow />
        <EmberStream />
        <TreeOfLife />
        <CanopyGlow />
      </Canvas>
    </div>
  );
}


