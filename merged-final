  const INTENT_MAP = STORE.INTENTS;
  const LOOKUP = useMemo(() => {
    const M = {};
    ASSET_NODES.forEach((N) => (M[N.ID] = N));
    return M;
  }, [ASSET_NODES]);

  const INITIAL_CATS = useMemo(() => {
    const OBJ = {};
    Object.keys(ASSET_CATEGORIES).forEach((K) => (OBJ[K] = true));
    return OBJ;
  }, []);
  const [ACTIVE_CATS, SET_ACTIVE_CATS] = useState(INITIAL_CATS);
  const [SELECTED_ID, SET_SELECTED_ID] = useState("N_ESTATE");
  const [HOVER_ID, SET_HOVER_ID] = useState(null);
  const [ISOLATED, SET_ISOLATED] = useState(false);

  const SELECT_NODE = (ID) => {
    SET_SELECTED_ID(ID);
    SET_ISOLATED(false);
  };

  const SELECTED = SELECTED_ID ? LOOKUP[SELECTED_ID] : null;
  const SELECTED_INTENT = SELECTED && INTENT_MAP[SELECTED.ID] ? INTENT_MAP[SELECTED.ID].INTENT : null;

  const TOGGLE_CAT = (KEY) => {
    SET_ACTIVE_CATS((PREV) => ({ ...PREV, [KEY]: !PREV[KEY] }));
  };

  const CONNECTED = useMemo(() => {
    if (!SELECTED_ID) return [];
    const LIST = [];
    ASSET_EDGES.forEach((E) => {
      if (E.FROM === SELECTED_ID) LIST.push(LOOKUP[E.TO]);
      if (E.TO === SELECTED_ID) LIST.push(LOOKUP[E.FROM]);
    });
    return LIST.filter(Boolean);
  }, [SELECTED_ID, LOOKUP]);

  const FOCUS_SET = useMemo(() => {
    if (!ISOLATED || !SELECTED_ID) return null;
    return new Set([SELECTED_ID, ...CONNECTED.map((C) => C.ID)]);
  }, [ISOLATED, SELECTED_ID, CONNECTED]);

  const VISIBLE_COUNT = ASSET_NODES.filter((N) => ACTIVE_CATS[N.CATEGORY]).length;

  return (
    <div className="view">
      <div className="view-head">
        <span className="eyebrow"><IconGraph SIZE={14} /> Layer 1 · Step 02</span>
