// ======================================================================
// ENGINE API CLIENT
// Thin wrapper around the FastAPI backend (backend/app.py). In dev, calls go
// through the Vite proxy at "/api" -> http://127.0.0.1:8000. Every call is
// defensive: network/HTTP failures reject with a readable message so the
// store can fall back to local-only behaviour when the engine is offline.
// ======================================================================

// Dev: Vite proxy at /api. Single-file: in-browser engine. Server: same origin.
import { dispatchEngineRequest } from "./inline-engine.js";

const SINGLE_FILE = import.meta.env.VITE_SINGLE_FILE === "true";
const API_BASE = import.meta.env.DEV ? "/api" : "";
const TIMEOUT_MS = 8000;

async function REQUEST(PATH, { METHOD = "GET", BODY } = {}) {
  if (SINGLE_FILE) {
    const RES = await dispatchEngineRequest(PATH, { METHOD, BODY });
    if (!RES.ok) {
      const DETAIL = RES.data && RES.data.detail ? RES.data.detail : `HTTP ${RES.status}`;
      throw new Error(typeof DETAIL === "string" ? DETAIL : JSON.stringify(DETAIL));
    }
    return RES.data;
  }

  const CONTROLLER = new AbortController();
  const TIMER = setTimeout(() => CONTROLLER.abort(), TIMEOUT_MS);
  try {
    const RES = await fetch(`${API_BASE}${PATH}`, {
      method: METHOD,
      headers: BODY ? { "Content-Type": "application/json" } : undefined,
      body: BODY ? JSON.stringify(BODY) : undefined,
      signal: CONTROLLER.signal,
    });
    const TEXT = await RES.text();
    const DATA = TEXT ? JSON.parse(TEXT) : null;
    if (!RES.ok) {
      const DETAIL = DATA && DATA.detail ? DATA.detail : `HTTP ${RES.status}`;
      throw new Error(typeof DETAIL === "string" ? DETAIL : JSON.stringify(DETAIL));
    }
    return DATA;
  } finally {
    clearTimeout(TIMER);
  }
}

export const ENGINE_API = {
  HEALTH: () => REQUEST("/health"),

  // ---- Layer 1 · Enrollment / Asset Graph ----
  ENROLL_ASSET: (PAYLOAD) => REQUEST("/layer1/assets", { METHOD: "POST", BODY: PAYLOAD }),
  LIST_ASSETS: () => REQUEST("/layer1/assets"),
  GRAPH_ORDER: () => REQUEST("/layer1/graph/order"),

  // ---- Layer 2 · Verification / Consensus ----
  REGISTRY_HIT: (CASE_ID, DECEASED_NAME, DEATH_CERTIFICATE_ID) =>
    REQUEST("/layer2/registry-hit", {
      METHOD: "POST",
      BODY: { case_id: CASE_ID, deceased_name: DECEASED_NAME, death_certificate_id: DEATH_CERTIFICATE_ID },
    }),
  ATTESTATION: (CASE_ID, CONTACT_ID) =>
    REQUEST("/layer2/attestation", { METHOD: "POST", BODY: { case_id: CASE_ID, contact_id: CONTACT_ID } }),
  DEAD_MAN: (CASE_ID, ARMED, INACTIVITY_DAYS) =>
    REQUEST("/layer2/dead-man", { METHOD: "POST", BODY: { case_id: CASE_ID, armed: ARMED, inactivity_days: INACTIVITY_DAYS } }),
  VERIFICATION: (CASE_ID) => REQUEST(`/layer2/verification/${encodeURIComponent(CASE_ID)}`),

  // ---- Layer 3 · Execution / Workflows ----
  EXECUTE: (CASE_ID, FORCE_SKIP_COOLING_OFF = true) =>
    REQUEST("/layer3/execute", { METHOD: "POST", BODY: { case_id: CASE_ID, force_skip_cooling_off: FORCE_SKIP_COOLING_OFF } }),
  CHECKPOINT: (WORKFLOW_ID, APPROVED = true) =>
    REQUEST("/layer3/checkpoint", { METHOD: "POST", BODY: { workflowid: WORKFLOW_ID, approved: APPROVED } }),
  ADVANCE: (WORKFLOW_ID) => REQUEST(`/layer3/advance/${encodeURIComponent(WORKFLOW_ID)}`, { METHOD: "POST" }),
  WORKFLOWS: (CASE_ID) => REQUEST(`/layer3/workflows${CASE_ID ? `?case_id=${encodeURIComponent(CASE_ID)}` : ""}`),
};

// ---- Map a frontend asset (+ its intent) to a backend enrollment request ----
const CATEGORY_MAP = {
  FINANCIAL: "financial",
  SUBSCRIPTION: "subscription",
  CRYPTO: "financial",
  SOCIAL: "media",
  DOCUMENT: "correspondence",
};

const INTENT_MAP = {
  TRANSFER: "transfer",
  CANCEL: "cancel",
  ARCHIVE: "archive",
  MEMORIALIZE: "archive",
};

// Parse a monthly rupee value like "₹299 / mo" -> 299.0 (0 when not monthly).
function PARSE_MONTHLY(VALUE) {
  if (typeof VALUE !== "string" || !/mo/i.test(VALUE)) return 0;
  const NUM = VALUE.replace(/[^\d.]/g, "");
  const N = Number(NUM);
  return Number.isFinite(N) ? N : 0;
}

export function ASSET_TO_ENROLLMENT(ASSET, INTENT) {
  const PROVIDER = (ASSET.PROVIDER || ASSET.NAME || "unknown").toLowerCase().replace(/[^a-z0-9]+/g, "_").replace(/^_|_$/g, "");
  return {
    assetid: ASSET.ID.toLowerCase(),
    providername: PROVIDER || "unknown",
    assetcategory: CATEGORY_MAP[ASSET.CATEGORY] || "correspondence",
    dispositionintent: INTENT_MAP[INTENT && INTENT.INTENT] || "archive",
    beneficiaryid: (INTENT && INTENT.ROUTE_TO) || null,
    financial_value_monthly: PARSE_MONTHLY(ASSET.VALUE),
    metadata: { source: "living-enrollment-frontend", label: ASSET.NAME },
  };
}


