      APPEND_AUDIT("Aarav Sharma", "AUDIT_EXPORTED", `${FORMAT.LABEL} · ${JURISDICTION}`);
      SET_GENERATING(false);
      PUSH_TOAST("Audit certificate generated & downloaded ✓");
    }, 1200);
  };

  return (
    <div className="view">
      <div className="view-head">
        <span className="eyebrow"><IconAudit SIZE={14} /> Layer 5 · Compliance</span>
        <h1 className="view-title">Legally Admissible Audit Trail</h1>
        <p className="view-desc">
          Every action across Legacy Ledger Co. is written to a tamper-evident, hash-linked ledger. Reformat it on demand
