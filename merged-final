function BrandOrb({ ACCENT }) {
  const GROUP_REF = useRef();
  const DOTS = useMemo(() => new THREE.TorusKnotGeometry(0.9, 0.28, 128, 16).attributes.position.array, []);
  const COUNT = DOTS.length / 3;
  const COLOR = useMemo(() => new THREE.Color(ACCENT), [ACCENT]);

  useFrame((STATE, DELTA) => {
    GROUP_REF.current.rotation.y += DELTA * 0.5;
    GROUP_REF.current.rotation.z += DELTA * 0.12;
    GROUP_REF.current.children[0].material.color.lerp(COLOR, 0.1);
  });

  return (
    <group ref={GROUP_REF}>
      <points>
        <bufferGeometry>
          <bufferAttribute attach="attributes-position" count={COUNT} array={DOTS} itemSize={3} />
        </bufferGeometry>
        <pointsMaterial color={ACCENT} size={0.04} sizeAttenuation transparent opacity={0.95} blending={THREE.AdditiveBlending} depthWrite={false} />
      </points>
    </group>
  );
}

