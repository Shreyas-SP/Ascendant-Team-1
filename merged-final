#!/usr/bin/env python3
"""
Legacy Ledger Co. — single-file launcher
========================================
Double-click this file, or run:

    python3 LegacyLedger.py

It will:
  1. Build the React frontend (once, into dist/)
  2. Start the FastAPI backend
  3. Serve the full website + API on one port
  4. Open your browser automatically

Press Ctrl+C in the terminal to stop.
"""

from __future__ import annotations

import os
import shutil
import subprocess
import sys
import threading
import time
import webbrowser
from pathlib import Path

ROOT = Path(__file__).resolve().parent
BACKEND = ROOT / "backend"
DIST = ROOT / "dist"
VENV = BACKEND / ".venv"
PORT = 8765
URL = f"http://127.0.0.1:{PORT}"


def _run(cmd: list[str], *, cwd: Path | None = None, check: bool = True) -> subprocess.CompletedProcess:
    print(f"  → {' '.join(cmd)}")
    return subprocess.run(cmd, cwd=cwd or ROOT, check=check)


def _which(name: str) -> str | None:
    return shutil.which(name)


def ensure_backend_venv() -> Path:
    """Create backend venv + install Python deps if missing."""
    py = VENV / "bin" / "python"
    if not py.exists():
        print("\n[1/3] Creating Python environment…")
        _run([sys.executable, "-m", "venv", str(VENV)])
        _run([str(VENV / "bin" / "pip"), "install", "--upgrade", "pip"], check=False)
        _run([str(VENV / "bin" / "pip"), "install", "-r", "requirements.txt"], cwd=BACKEND)
    return py


def ensure_frontend_build() -> None:
    """Build the React app into dist/ if not already built."""
    if (DIST / "index.html").exists():
        print("\n[2/3] Frontend build found — skipping npm build")
        return

    npm = _which("npm")
    if not npm:
        print("\nERROR: npm not found. Install Node.js from https://nodejs.org then re-run.")
        sys.exit(1)

    if not (ROOT / "node_modules").is_dir():
        print("\n[2/3] Installing frontend dependencies…")
        _run([npm, "install"])

    print("\n[2/3] Building frontend (first run only)…")
    _run([npm, "run", "build"])

    if not (DIST / "index.html").exists():
        print("ERROR: Frontend build failed — dist/index.html missing.")
        sys.exit(1)


def open_browser_later() -> None:
    time.sleep(1.2)
    webbrowser.open(URL)


def main() -> None:
    print("=" * 60)
    print("  Legacy Ledger Co. · Living Enrollment")
    print("  One-file launcher — frontend + backend combined")
    print("=" * 60)

    ensure_backend_venv()
    ensure_frontend_build()

    print(f"\n[3/3] Starting server at {URL}")
    print("      Press Ctrl+C to stop.\n")

    threading.Thread(target=open_browser_later, daemon=True).start()

    os.chdir(BACKEND)
    sys.path.insert(0, str(BACKEND))

    import uvicorn

    uvicorn.run("app:app", host="127.0.0.1", port=PORT, log_level="warning")


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\nStopped.")


