        },
        TRUSTEE_QUORUM: {
          ...TRIGGERS_DEFAULT.TRUSTEE_QUORUM,
          ...(TRIGGERS_SAVED.TRUSTEE_QUORUM || {}),
          SIGNATURES: (TRIGGERS_SAVED.TRUSTEE_QUORUM && TRIGGERS_SAVED.TRUSTEE_QUORUM.SIGNATURES) || {},
        },
        INACTIVITY: {
          ...TRIGGERS_DEFAULT.INACTIVITY,
          ...(TRIGGERS_SAVED.INACTIVITY || {}),
        },
      },
      POST_DEATH: {
        ...DEFAULT.ACTIVATION.POST_DEATH,
        ...((PARSED.ACTIVATION && PARSED.ACTIVATION.POST_DEATH) || {}),
      },
      DEATH_RECORD: (PARSED.ACTIVATION && PARSED.ACTIVATION.DEATH_RECORD) || null,
    },
    PACKET: { ...DEFAULT.PACKET, ...(PARSED.PACKET || {}) },
    BILLING: { ...DEFAULT.BILLING, ...(PARSED.BILLING || {}) },
    ACCOUNTS: { ...DEFAULT.ACCOUNTS, ...(PARSED.ACCOUNTS || {}) },
  };
}

function LOAD_STATE() {
  const DEFAULT = BUILD_DEFAULT_STATE();
  try {
    let RAW = localStorage.getItem(STORAGE_KEY);
    // Migrate older key so a reload after the V2 bump doesn't wipe progress.
    if (!RAW) {
      const LEGACY = localStorage.getItem(STORAGE_KEY_LEGACY);
      if (LEGACY) {
        RAW = LEGACY;
        try {
          localStorage.setItem(STORAGE_KEY, LEGACY);
          localStorage.removeItem(STORAGE_KEY_LEGACY);
        } catch { /* keep reading from memory merge below */ }
      }
    }
    if (!RAW) return DEFAULT;
    let MERGED = MERGE_ESTATE(DEFAULT, JSON.parse(RAW));
    try {
      const SIG_RAW = localStorage.getItem(STORAGE_KEY_SIGS);
      if (SIG_RAW) MERGED = REHYDRATE_SIGNATURES(MERGED, JSON.parse(SIG_RAW));
    } catch { /* signatures optional */ }
    return MERGED;
  } catch {
    return DEFAULT;
  }
}

function PERSIST_ESTATE(STORE) {
  // Keep heavy ink out of the main blob so activation progress always survives reload.
  const CORE = STRIP_SIGNATURE_DATA(STORE);
  const SIGS = EXTRACT_SIGNATURES(STORE);
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(CORE));
  } catch (ERR) {
    return { OK: false, ERROR: ERR && ERR.message };
  }
  try {
    localStorage.setItem(STORAGE_KEY_SIGS, JSON.stringify(SIGS));
  } catch {
    // Core estate still saved — signatures may be missing after reload, votes remain.
  }
  return { OK: true };
}

const EstateContext = createContext(null);

export function EstateProvider({ children }) {
  const [STORE, SET_STORE] = useState(LOAD_STATE);
  const [TOASTS, SET_TOASTS] = useState([]);

  // ---- Persistence (survives reload; falls back if signature ink exceeds quota) ----
  useEffect(() => {
    const RESULT = PERSIST_ESTATE(STORE);
    if (!RESULT.OK) {
      SET_TOASTS((T) => [
        ...T.slice(-4),
        { ID: `T_${Date.now()}`, TEXT: "Could not save estate to this browser — progress may reset on reload", TONE: "warn" },
      ]);
    }
  }, [STORE]);

  // ---- Live theme (white-label re-brand) ----
  useEffect(() => {
    const ROOT = document.documentElement;
    if (STORE.BRAND.ACCENT) {
      ROOT.style.setProperty("--VIOLET", STORE.BRAND.ACCENT);
      ROOT.style.setProperty("--VIOLET-2", STORE.BRAND.ACCENT);
    } else {
      ROOT.style.removeProperty("--VIOLET");
      ROOT.style.removeProperty("--VIOLET-2");
    }
  }, [STORE.BRAND.ACCENT]);

  const PUSH_TOAST = useCallback((MESSAGE, TONE = "ok") => {
    const ID = Date.now() + Math.random();
    SET_TOASTS((PREV) => [...PREV, { ID, MESSAGE, TONE }]);
    setTimeout(() => SET_TOASTS((PREV) => PREV.filter((T) => T.ID !== ID)), 2800);
  }, []);

  const PATCH = useCallback((FN) => SET_STORE((PREV) => FN(PREV)), []);

  // ---- Immutable audit trail: append a hash-linked event ----
  const APPEND_AUDIT = useCallback((ACTOR, ACTION, TARGET) => {
    SET_STORE((PREV) => {
      const LAST = PREV.AUDIT[PREV.AUDIT.length - 1];
      const EVT = {
        ID: `AE_${PREV.AUDIT.length + 1}_${Math.floor(Math.random() * 1000)}`,
        SEQ: PREV.AUDIT.length + 1,
        ACTOR,
        ACTION,
        TARGET,
        TIME: NOW_IST(),
        HASH: MAKE_HASH(),
        PREV: LAST ? LAST.HASH : "0000…0000",
      };
      return { ...PREV, AUDIT: [...PREV.AUDIT, EVT] };
    });
  }, []);

  // ================= PROFILE =================
  const SET_PROFILE_FIELD = useCallback((KEY, VALUE) => {
    PATCH((S) => ({ ...S, PROFILE: { ...S.PROFILE, [KEY]: VALUE } }));
  }, [PATCH]);

  const SAVE_PROFILE = useCallback(() => {
    let NAME = "";
    SET_STORE((S) => {
      NAME = S.PROFILE.FULL_NAME;
      return { ...S, PROFILE: { ...S.PROFILE, SAVED: true } };
    });
    APPEND_AUDIT(NAME || "Principal", "SEALED_ENROLLMENT", "Estate Vault");
    PUSH_TOAST("Identity saved & encrypted to your vault");
  }, [APPEND_AUDIT, PUSH_TOAST]);

  // Set one beneficiary's share, then redistribute the leftover across the
  // others in their existing ratio so allocations always total exactly 100%.
  const UPDATE_SHARE = useCallback((ID, NEXT) => {
    PATCH((S) => {
      const LIST = S.BENEFICIARIES;
      if (LIST.length === 0) return S;
      if (LIST.length === 1) return { ...S, BENEFICIARIES: LIST.map((B) => ({ ...B, SHARE: 100 })) };

      const TARGET = Math.max(0, Math.min(100, Math.round(NEXT)));
      const REMAINING = 100 - TARGET;
      const OTHERS = LIST.filter((B) => B.ID !== ID);
      const OTHERS_TOTAL = OTHERS.reduce((SUM, B) => SUM + B.SHARE, 0);

      // Proportional weights; fall back to an even split if the others are all zero.
      const RAW = OTHERS.map((B) => (OTHERS_TOTAL > 0 ? (B.SHARE / OTHERS_TOTAL) * REMAINING : REMAINING / OTHERS.length));

      // Largest-remainder rounding keeps the others summing to REMAINING exactly.
      const FLOORS = RAW.map((V) => Math.floor(V));
      let LEFT = REMAINING - FLOORS.reduce((SUM, V) => SUM + V, 0);
      const ORDER = RAW.map((V, I) => ({ I, FRAC: V - Math.floor(V) })).sort((A, B) => B.FRAC - A.FRAC);
      const ALLOC = [...FLOORS];
      for (let K = 0; K < ORDER.length && LEFT > 0; K++, LEFT--) ALLOC[ORDER[K].I] += 1;

      let J = 0;
      const NEXT_LIST = LIST.map((B) => (B.ID === ID ? { ...B, SHARE: TARGET } : { ...B, SHARE: ALLOC[J++] }));
      return { ...S, BENEFICIARIES: NEXT_LIST };
    });
  }, [PATCH]);

  const ADD_BENEFICIARY = useCallback((NAME, ROLE) => {
    const PALETTE = ["#7c6cff", "#64e9d0", "#ffb86b", "#ff7597", "#57e389", "#9d7bff"];
    PATCH((S) => {
      const COLOR = PALETTE[S.BENEFICIARIES.length % PALETTE.length];
      const B = { ID: `B_${Date.now()}`, NAME, ROLE: ROLE || "Beneficiary", SHARE: 0, COLOR };
      return { ...S, BENEFICIARIES: [...S.BENEFICIARIES, B] };
    });
    APPEND_AUDIT("Aarav Sharma", "BENEFICIARY_ADDED", NAME);
    PUSH_TOAST(`${NAME} added as a beneficiary`);
  }, [PATCH, APPEND_AUDIT, PUSH_TOAST]);

  const REMOVE_BENEFICIARY = useCallback((ID) => {
    PATCH((S) => ({ ...S, BENEFICIARIES: S.BENEFICIARIES.filter((B) => B.ID !== ID) }));
    PUSH_TOAST("Beneficiary removed");
  }, [PATCH, PUSH_TOAST]);

  // ================= INTENTS → JOBS =================
  const ASSIGN_INTENT = useCallback((NODE_ID, INTENT_ID) => {
    PATCH((S) => {
      const NODE = S.ASSETS.find((A) => A.ID === NODE_ID);
      const PREV_INTENT = S.INTENTS[NODE_ID] || { ROUTE_TO: "", PRIORITY: "STANDARD", NOTE: "" };
      const INTENTS = { ...S.INTENTS, [NODE_ID]: { ...PREV_INTENT, INTENT: INTENT_ID } };

      let JOBS = S.JOBS.slice();
      const IDX = JOBS.findIndex((J) => J.NODE_ID === NODE_ID);
      if (IDX >= 0) {
        JOBS[IDX] = { ...JOBS[IDX], ACTION: INTENT_ID };
      } else if (NODE) {
        JOBS.push({
          ID: `JOB_${NODE_ID}`,
          NODE_ID,
          TARGET: NODE.NAME,
          PROVIDER: NODE.PROVIDER,
          ACTION: INTENT_ID,
          STATE: "QUEUED",
          PROGRESS: 0,
          STAGE: 0,
          LATENCY: "—",
        });
      }
      return { ...S, INTENTS, JOBS };
    });
  }, [PATCH]);

  const SET_INTENT_META = useCallback((NODE_ID, KEY, VALUE) => {
    PATCH((S) => {
      const PREV = S.INTENTS[NODE_ID] || { INTENT: null, ROUTE_TO: "", PRIORITY: "STANDARD", NOTE: "" };
      return { ...S, INTENTS: { ...S.INTENTS, [NODE_ID]: { ...PREV, [KEY]: VALUE } } };
    });
  }, [PATCH]);

  const AUTO_CLASSIFY = useCallback(() => {
    const SUGGESTION = { FINANCIAL: "TRANSFER", CRYPTO: "TRANSFER", SUBSCRIPTION: "CANCEL", DOCUMENT: "ARCHIVE", SOCIAL: "MEMORIALIZE" };
    PATCH((S) => {
      const INTENTS = { ...S.INTENTS };
      let JOBS = S.JOBS.slice();
      S.ASSETS.filter((A) => !A.IS_ROOT).forEach((NODE) => {
        const INTENT_ID = SUGGESTION[NODE.CATEGORY];
        const PREV = INTENTS[NODE.ID] || { ROUTE_TO: "", PRIORITY: "STANDARD", NOTE: "" };
        INTENTS[NODE.ID] = { ...PREV, INTENT: INTENT_ID };
        const IDX = JOBS.findIndex((J) => J.NODE_ID === NODE.ID);
        if (IDX >= 0) JOBS[IDX] = { ...JOBS[IDX], ACTION: INTENT_ID };
        else JOBS.push({ ID: `JOB_${NODE.ID}`, NODE_ID: NODE.ID, TARGET: NODE.NAME, PROVIDER: NODE.PROVIDER, ACTION: INTENT_ID, STATE: "QUEUED", PROGRESS: 0, STAGE: 0, LATENCY: "—" });
      });
      return { ...S, INTENTS, JOBS };
    });
    PUSH_TOAST("Smart classification applied to every asset");
  }, [PATCH, PUSH_TOAST]);

  // ================= ACCOUNTS =================
  const LINK_BANK = useCallback((INSTITUTION) => {
    PATCH((S) => {
      if (S.ACCOUNTS.BANKS.includes(INSTITUTION.NAME)) return S;
      // Linking a bank materialises a real asset node in the estate graph.
      const NEW_NODE = {
        ID: `N_${INSTITUTION.ID}`,
        NAME: `${INSTITUTION.NAME} A/C`,
        CATEGORY: "FINANCIAL",
        VALUE: `₹${(Math.floor(Math.random() * 40) + 5).toLocaleString("en-IN")},000`,
        POSITION: [(Math.random() - 0.5) * 6, (Math.random() - 0.5) * 6, (Math.random() - 0.5) * 4],
        PROVIDER: INSTITUTION.NAME,
      };
      const EXISTS = S.ASSETS.some((A) => A.ID === NEW_NODE.ID);
      return {
        ...S,
        ACCOUNTS: { ...S.ACCOUNTS, BANKS: [...S.ACCOUNTS.BANKS, INSTITUTION.NAME] },
        ASSETS: EXISTS ? S.ASSETS : [...S.ASSETS, NEW_NODE],
      };
    });
    APPEND_AUDIT("System", "AA_LINKED", INSTITUTION.NAME);
    PUSH_TOAST(`${INSTITUTION.NAME} linked · account added to graph`);
  }, [PATCH, APPEND_AUDIT, PUSH_TOAST]);

  const TOGGLE_PROVIDER = useCallback((ID, NAME) => {
    let NEXT_STATUS = "";
    PATCH((S) => ({
      ...S,
      ACCOUNTS: {
        ...S.ACCOUNTS,
        PROVIDERS: S.ACCOUNTS.PROVIDERS.map((P) => {
          if (P.ID !== ID) return P;
          NEXT_STATUS = P.STATUS === "LINKED" ? "UNLINKED" : "LINKED";
          return { ...P, STATUS: NEXT_STATUS };
        }),
      },
    }));
    APPEND_AUDIT("Aarav Sharma", NEXT_STATUS === "LINKED" ? "OAUTH_GRANTED" : "OAUTH_REVOKED", NAME);
    PUSH_TOAST(`${NAME} ${NEXT_STATUS === "LINKED" ? "authorized" : "revoked"}`);
  }, [PATCH, APPEND_AUDIT, PUSH_TOAST]);

  // ================= WORKFLOW / EXECUTION =================
  const RETRY_JOB = useCallback((JOB_ID) => {
    PATCH((S) => ({ ...S, JOBS: S.JOBS.map((J) => (J.ID === JOB_ID ? { ...J, STATE: "RUNNING", PROGRESS: Math.max(5, J.PROGRESS) } : J)) }));
    PUSH_TOAST("Job requeued to the executor");
  }, [PATCH, PUSH_TOAST]);

  const DISPATCH_QUEUED = useCallback(() => {
    let COUNT = 0;
    PATCH((S) => ({
      ...S,
      JOBS: S.JOBS.map((J) => {
        if (J.STATE === "QUEUED") { COUNT++; return { ...J, STATE: "RUNNING", PROGRESS: Math.max(4, J.PROGRESS) }; }
        return J;
      }),
    }));
    PUSH_TOAST(COUNT ? `${COUNT} queued job(s) dispatched` : "No queued jobs to dispatch");
  }, [PATCH, PUSH_TOAST]);

  const RESOLVE_EXCEPTION = useCallback((EXC_ID) => {
    const EXC = EXCEPTION_QUEUE.find((E) => E.ID === EXC_ID);
    PATCH((S) => {
      if (S.RESOLVED_EXCEPTIONS.includes(EXC_ID)) return S;
      const JOBS = EXC
        ? S.JOBS.map((J) => (J.ID === EXC.JOB_ID ? { ...J, STATE: "RUNNING", PROGRESS: Math.max(5, J.PROGRESS) } : J))
        : S.JOBS;
      return { ...S, RESOLVED_EXCEPTIONS: [...S.RESOLVED_EXCEPTIONS, EXC_ID], JOBS };
    });
    if (EXC) APPEND_AUDIT("Operator", "EXCEPTION_CLEARED", `${EXC.PROVIDER} · ${EXC.KIND}`);
    PUSH_TOAST(`${EXC ? EXC.TARGET : "Exception"} cleared — job resumed`);
  }, [PATCH, APPEND_AUDIT, PUSH_TOAST]);

  // Shared real-time execution ticker: advance RUNNING jobs, log on completion.
  const AUDIT_REF = useRef(APPEND_AUDIT);
  AUDIT_REF.current = APPEND_AUDIT;
  const STORE_REF = useRef(STORE);
  STORE_REF.current = STORE;
  useEffect(() => {
    const TIMER = setInterval(() => {
      SET_STORE((S) => {
        let CHANGED = false;
        const COMPLETED = [];
        const JOBS = S.JOBS.map((J) => {
          if (J.STATE !== "RUNNING") return J;
          CHANGED = true;
          const NEXT = Math.min(100, J.PROGRESS + Math.random() * 7);
          const STAGE = Math.min(WORKFLOW_STAGES.length, Math.ceil((NEXT / 100) * WORKFLOW_STAGES.length));
          if (NEXT >= 100) {
            COMPLETED.push(J);
            return { ...J, PROGRESS: 100, STAGE: WORKFLOW_STAGES.length, STATE: "SUCCESS", LATENCY: `${(3 + Math.random() * 5).toFixed(1)}s` };
          }
          return { ...J, PROGRESS: NEXT, STAGE };
        });
        if (COMPLETED.length) {
          setTimeout(() => COMPLETED.forEach((J) => AUDIT_REF.current("Worker/ap-south-1", "DIRECTIVE_EXECUTED", `${J.TARGET} · ${J.ACTION}`)), 0);
        }
        return CHANGED ? { ...S, JOBS } : S;
      });
    }, 900);
    return () => clearInterval(TIMER);
  }, []);

  // ================= ACTIVATION =================
  // ---- Life / Death lifecycle + post-death execution simulation ----
  const PD_TIMERS = useRef([]);
  const FIRING_REF = useRef(false);

  const RUN_POST_DEATH_SEQUENCE = useCallback(() => {
    PD_TIMERS.current.forEach(clearTimeout);
    PD_TIMERS.current = [];

    const STEP = (I) => {
      if (I >= POST_DEATH_STAGES.length) {
        FIRING_REF.current = false;
        PATCH((S) => ({
          ...S,
          ACTIVATION: {
            ...S.ACTIVATION,
            LIFE_STATUS: "DECEASED",
            ARMED: false,
            TRIGGERED: true,
            POST_DEATH: { RUNNING: false, STAGE: POST_DEATH_STAGES.length, DONE: true },
            TIMELINE: S.ACTIVATION.TIMELINE.map((T) =>
              T.ID === "TL_5" ? { ...T, DONE: true, ACTIVE: false, WHEN: NOW_IST().split(" ")[0] } : T
            ),
          },
        }));
        AUDIT_REF.current("Legacy Ledger Engine", "ESTATE_EXECUTION_COMPLETE", "All directives dispatched · packet delivered");
        PUSH_TOAST("Estate execution complete — legacy packet delivered to heirs", "warn");
        return;
      }

      const STAGE = POST_DEATH_STAGES[I];
      PATCH((S) => {
        let NEXT = { ...S, ACTIVATION: { ...S.ACTIVATION, POST_DEATH: { RUNNING: true, STAGE: I, DONE: false } } };
        // Each stage triggers the real consequence it describes.
        if (STAGE.ID === "PD_SHARDS") {
          NEXT = { ...NEXT, SHARDS: NEXT.SHARDS.map((SH) => ({ ...SH, RELEASED: true })) };
        } else if (STAGE.ID === "PD_EXECUTION") {
          NEXT = {
            ...NEXT,
            JOBS: NEXT.JOBS.map((J) => (J.STATE === "QUEUED" ? { ...J, STATE: "RUNNING", PROGRESS: Math.max(6, J.PROGRESS) } : J)),
          };
        } else if (STAGE.ID === "PD_PACKET") {
          NEXT = { ...NEXT, PACKET: { ...NEXT.PACKET, DECRYPTED: true } };
        }
        return NEXT;
      });
      AUDIT_REF.current("Legacy Ledger Engine", "POST_DEATH_STEP", STAGE.LABEL);

      PD_TIMERS.current.push(setTimeout(() => STEP(I + 1), 1200));
    };

    STEP(0);
  }, [PATCH, PUSH_TOAST]);

  // Shared entry point: any of the 3 activation cases that completes fires this.
  const FIRE_ACTIVATION = useCallback((SOURCE, EXTRA = {}) => {
    if (FIRING_REF.current) return false;
    FIRING_REF.current = true;
    const NOW = new Date();
    const SOURCE_META = {
      DEATH_CERTIFICATE: { MANNER: "Natural", ACTOR: "Registrar + Trustees", AUDIT: "Death certificate verified by trustee quorum" },
      TRUSTEE_QUORUM: { MANNER: "Attested", ACTOR: "Trustee quorum", AUDIT: "3-of-4 trustee quorum attested triggering event" },
      INACTIVITY: { MANNER: "Presumed (inactivity)", ACTOR: "Dead-man switch", AUDIT: "180-day inactivity threshold crossed · no proof-of-life" },
      MANUAL: { MANNER: "Natural", ACTOR: "Executor", AUDIT: "Certified death report filed" },
    }[SOURCE] || { MANNER: "Natural", ACTOR: "System", AUDIT: "Trigger verified" };

    PATCH((S) => {
      const EXECUTOR = (S.BENEFICIARIES.find((B) => /executor/i.test(B.ROLE)) || S.BENEFICIARIES[0] || {}).NAME || "Executor";
      const TRIGGERS = S.ACTIVATION.TRIGGERS || BUILD_DEFAULT_TRIGGERS();
      const WITNESS_SIGNATURES = [
        ...Object.values(TRIGGERS.DEATH_CERTIFICATE.SIGNATURES || {}),
        ...Object.values(TRIGGERS.TRUSTEE_QUORUM.SIGNATURES || {}),
      ];
      const DEATH_RECORD = {
        CERTIFICATE_ID: EXTRA.CERTIFICATE_ID || `DC-2026-${Math.floor(1000 + Math.random() * 8999)}`,
        DATE_OF_DEATH: NOW.toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" }),
        TIME_OF_RECORD: NOW_IST(),
        PLACE: S.PROFILE.JURISDICTION || "—",
        CAUSE: EXTRA.CAUSE || CAUSE_OF_DEATH_POOL[Math.floor(Math.random() * CAUSE_OF_DEATH_POOL.length)],
        CERTIFIED_BY: EXTRA.CERTIFIED_BY || `Registrar of Births & Deaths, ${(S.PROFILE.JURISDICTION || "").split(",")[0] || "India"}`,
        REPORTED_BY: EXTRA.REPORTED_BY || EXECUTOR,
        MANNER: SOURCE_META.MANNER,
        TRIGGER_SOURCE: SOURCE,
        WITNESS_SIGNATURES,
      };
      return {
        ...S,
        ACTIVATION: {
          ...S.ACTIVATION,
          LIFE_STATUS: "VERIFYING",
          ARMED: false,
          TRIGGERED: true,
          POST_DEATH: { RUNNING: true, STAGE: -1, DONE: false },
          DEATH_RECORD,
          TIMELINE: S.ACTIVATION.TIMELINE.map((T) =>
            T.ID === "TL_4" ? { ...T, DONE: true, ACTIVE: false, WHEN: NOW_IST().split(" ")[0] } : T.ID === "TL_5" ? { ...T, ACTIVE: true, WHEN: "In progress" } : T
          ),
        },
        JOBS: S.JOBS.map((J) => (J.STATE === "QUEUED" ? { ...J, STATE: "RUNNING", PROGRESS: Math.max(4, J.PROGRESS) } : J)),
      };
    });
    APPEND_AUDIT(SOURCE_META.ACTOR, "TRIGGER_VERIFIED", SOURCE_META.AUDIT);
    PUSH_TOAST(`Trigger verified (${SOURCE.replace(/_/g, " ").toLowerCase()}) — execution sequence begun`, "warn");
    RUN_POST_DEATH_SEQUENCE();
    return true;
  }, [PATCH, APPEND_AUDIT, PUSH_TOAST, RUN_POST_DEATH_SEQUENCE]);

  const CHECK_IN = useCallback(() => {
    PATCH((S) => {
      if (S.ACTIVATION.LIFE_STATUS !== "LIVING") return S;
      return {
        ...S,
        ACTIVATION: {
          ...S.ACTIVATION,
          ARMED: true,
          TRIGGERED: false,
          DAYS_LEFT: 180,
          LAST_CHECKIN: NOW_IST(),
          TIMELINE: S.ACTIVATION.TIMELINE.map((T) =>
            T.ID === "TL_3" ? { ...T, DONE: true, WHEN: NOW_IST().split(" ")[0] } : T
          ),
        },
      };
    });
    APPEND_AUDIT("Aarav Sharma", "PROOF_OF_LIFE", "Biometric check-in");
    PUSH_TOAST("Proof-of-life recorded · inactivity timer reset to 180 days");
  }, [PATCH, APPEND_AUDIT, PUSH_TOAST]);

  // Case 1 — File a government death certificate (awaits 2 trustee confirmations).
  const FILE_DEATH_CERTIFICATE = useCallback(() => {
    let ALREADY = false;
    let CERT_ID = "";
    PATCH((S) => {
      if (S.ACTIVATION.LIFE_STATUS !== "LIVING") { ALREADY = true; return S; }
      const TRIGGERS = S.ACTIVATION.TRIGGERS || BUILD_DEFAULT_TRIGGERS();
      if (TRIGGERS.DEATH_CERTIFICATE.FILED) { ALREADY = true; return S; }
      CERT_ID = `DC-2026-${Math.floor(1000 + Math.random() * 8999)}`;
      return {
        ...S,
        ACTIVATION: {
          ...S.ACTIVATION,
          TRIGGERS: {
            ...TRIGGERS,
            DEATH_CERTIFICATE: {
              ...TRIGGERS.DEATH_CERTIFICATE,
              FILED: true,
              CERTIFICATE_ID: CERT_ID,
              CONFIRMATIONS: [],
            },
          },
        },
      };
    });
    if (ALREADY) return;
    APPEND_AUDIT("Registrar", "DEATH_CERTIFICATE_FILED", CERT_ID);
    PUSH_TOAST(`Death certificate ${CERT_ID} filed — awaiting 2 trustee confirmations`, "warn");
  }, [PATCH, APPEND_AUDIT, PUSH_TOAST]);

  // Case 1 confirmations require a contact e-signature before they count.
  const CONFIRM_DEATH_CERTIFICATE = useCallback((TRUSTEE_ID, SIGNATURE_DATA) => {
    if (!SIGNATURE_DATA) {
      PUSH_TOAST("Contact e-signature required to confirm death", "warn");
      return;
    }
    let SHOULD_FIRE = false;
    let CERT_ID = null;
    let TRUSTEE_NAME = "";
    PATCH((S) => {
      if (S.ACTIVATION.LIFE_STATUS !== "LIVING") return S;
      const TRIGGERS = S.ACTIVATION.TRIGGERS || BUILD_DEFAULT_TRIGGERS();
      const DC = TRIGGERS.DEATH_CERTIFICATE;
      if (!DC.FILED) return S;
      if (DC.CONFIRMATIONS.includes(TRUSTEE_ID)) return S;
      const TRUSTEE = NAMED_TRUSTEES.find((T) => T.ID === TRUSTEE_ID);
      TRUSTEE_NAME = TRUSTEE ? TRUSTEE.NAME : TRUSTEE_ID;
      CERT_ID = DC.CERTIFICATE_ID;
      const CONFIRMATIONS = [...DC.CONFIRMATIONS, TRUSTEE_ID];
      const SIGNATURES = {
        ...(DC.SIGNATURES || {}),
        [TRUSTEE_ID]: {
          DATA: SIGNATURE_DATA,
          SIGNED_AT: NOW_IST(),
          NAME: TRUSTEE_NAME,
          ROLE: TRUSTEE ? TRUSTEE.ROLE : "Trustee",
          PURPOSE: "Death certificate confirmation",
        },
      };
      SHOULD_FIRE = CONFIRMATIONS.length >= DC.NEEDED;
      return {
        ...S,
        ACTIVATION: {
          ...S.ACTIVATION,
          TRIGGERS: {
            ...TRIGGERS,
            DEATH_CERTIFICATE: { ...DC, CONFIRMATIONS, SIGNATURES },
          },
        },
      };
    });
    if (!TRUSTEE_NAME) return;
    APPEND_AUDIT(TRUSTEE_NAME, "DEATH_CERTIFICATE_SIGNED", CERT_ID || "certificate");
    PUSH_TOAST(`${TRUSTEE_NAME} e-signed death confirmation`);
    if (SHOULD_FIRE) {
      FIRE_ACTIVATION("DEATH_CERTIFICATE", {
        CERTIFICATE_ID: CERT_ID,
        REPORTED_BY: TRUSTEE_NAME,
        CERTIFIED_BY: `Registrar of Births & Deaths · e-signed by ${TRUSTEE_NAME}`,
      });
    }
  }, [PATCH, APPEND_AUDIT, PUSH_TOAST, FIRE_ACTIVATION]);

  // Case 2 — Trustee quorum: each attestation requires an e-signature until 3 of 4.
  const ATTEST_TRUSTEE = useCallback((TRUSTEE_ID, SIGNATURE_DATA) => {
    if (!SIGNATURE_DATA) {
      PUSH_TOAST("Contact e-signature required to attest death", "warn");
      return;
    }
    let SHOULD_FIRE = false;
    let TRUSTEE_NAME = "";
    let COUNT = 0;
    let NEEDED = 3;
    PATCH((S) => {
      if (S.ACTIVATION.LIFE_STATUS !== "LIVING") return S;
      const TRIGGERS = S.ACTIVATION.TRIGGERS || BUILD_DEFAULT_TRIGGERS();
      const TQ = TRIGGERS.TRUSTEE_QUORUM;
      if (TQ.ATTESTATIONS.includes(TRUSTEE_ID)) return S;
      const TRUSTEE = NAMED_TRUSTEES.find((T) => T.ID === TRUSTEE_ID);
      TRUSTEE_NAME = TRUSTEE ? TRUSTEE.NAME : TRUSTEE_ID;
      const ATTESTATIONS = [...TQ.ATTESTATIONS, TRUSTEE_ID];
      const SIGNATURES = {
        ...(TQ.SIGNATURES || {}),
        [TRUSTEE_ID]: {
          DATA: SIGNATURE_DATA,
          SIGNED_AT: NOW_IST(),
          NAME: TRUSTEE_NAME,
          ROLE: TRUSTEE ? TRUSTEE.ROLE : "Trustee",
          PURPOSE: "Death / triggering-event attestation",
        },
      };
      COUNT = ATTESTATIONS.length;
      NEEDED = TQ.NEEDED;
      SHOULD_FIRE = COUNT >= NEEDED;
      return {
        ...S,
        ACTIVATION: {
          ...S.ACTIVATION,
          TRIGGERS: {
            ...TRIGGERS,
            TRUSTEE_QUORUM: { ...TQ, ATTESTATIONS, SIGNATURES },
          },
        },
      };
    });
    if (!TRUSTEE_NAME) return;
    APPEND_AUDIT(TRUSTEE_NAME, "TRUSTEE_DEATH_SIGNED", "Triggering event attestation");
    PUSH_TOAST(`${TRUSTEE_NAME} e-signed attestation · quorum ${COUNT} / ${NEEDED}`);
    if (SHOULD_FIRE) {
      FIRE_ACTIVATION("TRUSTEE_QUORUM", {
        REPORTED_BY: `${COUNT}-of-${NAMED_TRUSTEES.length} trustee quorum (e-signed)`,
        CAUSE: "Triggering event jointly attested & e-signed by named trustees",
        CERTIFIED_BY: "Legacy Ledger Co. · Trustee Quorum Protocol",
      });
    }
  }, [PATCH, APPEND_AUDIT, PUSH_TOAST, FIRE_ACTIVATION]);

  // Demo helper — wipe only the 3 activation cases (and roll life status back to living).
  const RESET_ACTIVATION_CASES = useCallback(() => {
    PD_TIMERS.current.forEach(clearTimeout);
    PD_TIMERS.current = [];
    FIRING_REF.current = false;
    PATCH((S) => ({
      ...S,
      ACTIVATION: {
        ...S.ACTIVATION,
        LIFE_STATUS: "LIVING",
        ARMED: true,
        TRIGGERED: false,
        DAYS_LEFT: 180,
        LAST_CHECKIN: NOW_IST(),
        POST_DEATH: { RUNNING: false, STAGE: -1, DONE: false },
        DEATH_RECORD: null,
        TRIGGERS: BUILD_DEFAULT_TRIGGERS(),
        TIMELINE: ACTIVATION_TIMELINE.map((T) => ({ ...T })),
      },
      PACKET: { ...S.PACKET, DECRYPTED: false },
      SHARDS: PACKET_SHARDS.map((SH) => ({ ...SH })),
    }));
    APPEND_AUDIT("Operator", "ACTIVATION_CASES_RESET", "Trigger pathways cleared for demo");
    PUSH_TOAST("Activation cases reset — ready to demonstrate again");
  }, [PATCH, APPEND_AUDIT, PUSH_TOAST]);

  // Case 3 — Advance the inactivity / dead-man timer. Fires at 0 days left.
  const ADVANCE_INACTIVITY = useCallback((DAYS = 30) => {
    let SHOULD_FIRE = false;
    let LEFT = 0;
    PATCH((S) => {
      if (S.ACTIVATION.LIFE_STATUS !== "LIVING") return S;
      LEFT = Math.max(0, (S.ACTIVATION.DAYS_LEFT || 0) - DAYS);
      SHOULD_FIRE = LEFT <= 0;
      return {
        ...S,
        ACTIVATION: {
          ...S.ACTIVATION,
          DAYS_LEFT: LEFT,
          ARMED: !SHOULD_FIRE,
        },
      };
    });
    APPEND_AUDIT("System", "INACTIVITY_ADVANCED", `${DAYS} days elapsed`);
    if (SHOULD_FIRE) {
      PUSH_TOAST("180-day inactivity window exhausted — dead-man switch firing", "warn");
      FIRE_ACTIVATION("INACTIVITY", {
        CAUSE: "Extended inactivity — no verified proof-of-life for 180 days",
        CERTIFIED_BY: "Legacy Ledger Co. · Dead-man Switch",
        REPORTED_BY: "Automated inactivity monitor",
      });
    } else {
      PUSH_TOAST(`Inactivity advanced · ${LEFT} days remaining until trigger`, "warn");
    }
  }, [PATCH, APPEND_AUDIT, PUSH_TOAST, FIRE_ACTIVATION]);

  // Manual executor shortcut (same as filing a full death report).
  const REPORT_DECEASED = useCallback(() => {
    FIRE_ACTIVATION("MANUAL");
  }, [FIRE_ACTIVATION]);

  // Minimal placeholder signature used when "Complete armed case" auto-fills e-signs.
  const DEMO_SIGNATURE = (LABEL) => {
    const SVG = `<svg xmlns="http://www.w3.org/2000/svg" width="320" height="80"><text x="12" y="48" font-family="Georgia, serif" font-size="28" fill="#eef1ff">${LABEL}</text></svg>`;
    return `data:image/svg+xml;base64,${btoa(SVG)}`;
  };

  // Fire whichever activation case is currently selected on the profile.
  const SIMULATE_TRIGGER = useCallback(() => {
    let MODE = "DEATH_CERTIFICATE";
    PATCH((S) => {
      MODE = S.PROFILE.ACTIVATION || "DEATH_CERTIFICATE";
      if (S.ACTIVATION.LIFE_STATUS !== "LIVING") return S;
      const TRIGGERS = S.ACTIVATION.TRIGGERS || BUILD_DEFAULT_TRIGGERS();
      if (MODE === "DEATH_CERTIFICATE") {
        const CERT_ID = TRIGGERS.DEATH_CERTIFICATE.CERTIFICATE_ID || `DC-2026-${Math.floor(1000 + Math.random() * 8999)}`;
        const PICK = NAMED_TRUSTEES.slice(0, 2);
        const SIGNATURES = {};
        PICK.forEach((T) => {
          SIGNATURES[T.ID] = {
            DATA: DEMO_SIGNATURE(T.NAME),
            SIGNED_AT: NOW_IST(),
            NAME: T.NAME,
            ROLE: T.ROLE,
            PURPOSE: "Death certificate confirmation",
          };
        });
        return {
          ...S,
          ACTIVATION: {
            ...S.ACTIVATION,
            TRIGGERS: {
              ...TRIGGERS,
              DEATH_CERTIFICATE: {
                ...TRIGGERS.DEATH_CERTIFICATE,
                FILED: true,
                CERTIFICATE_ID: CERT_ID,
                CONFIRMATIONS: PICK.map((T) => T.ID),
                SIGNATURES,
              },
            },
          },
        };
      }
      if (MODE === "TRUSTEE_QUORUM") {
        const PICK = NAMED_TRUSTEES.slice(0, 3);
        const SIGNATURES = {};
        PICK.forEach((T) => {
          SIGNATURES[T.ID] = {
            DATA: DEMO_SIGNATURE(T.NAME),
            SIGNED_AT: NOW_IST(),
            NAME: T.NAME,
            ROLE: T.ROLE,
            PURPOSE: "Death / triggering-event attestation",
          };
        });
        return {
          ...S,
          ACTIVATION: {
            ...S.ACTIVATION,
            TRIGGERS: {
              ...TRIGGERS,
              TRUSTEE_QUORUM: {
                ...TRIGGERS.TRUSTEE_QUORUM,
                ATTESTATIONS: PICK.map((T) => T.ID),
                SIGNATURES,
              },
            },
          },
        };
      }
      // INACTIVITY
      return {
        ...S,
        ACTIVATION: { ...S.ACTIVATION, DAYS_LEFT: 0, ARMED: false },
      };
    });
    setTimeout(() => FIRE_ACTIVATION(MODE), 40);
  }, [PATCH, FIRE_ACTIVATION]);

  const RESTORE_LIVING = useCallback(() => {
    PD_TIMERS.current.forEach(clearTimeout);
    PD_TIMERS.current = [];
    FIRING_REF.current = false;
    PATCH((S) => ({
      ...S,
      ACTIVATION: {
        ...S.ACTIVATION,
        LIFE_STATUS: "LIVING",
        ARMED: true,
        TRIGGERED: false,
        DAYS_LEFT: 180,
        LAST_CHECKIN: NOW_IST(),
        POST_DEATH: { RUNNING: false, STAGE: -1, DONE: false },
        DEATH_RECORD: null,
        TRIGGERS: BUILD_DEFAULT_TRIGGERS(),
        TIMELINE: ACTIVATION_TIMELINE.map((T) => ({ ...T })),
      },
      PACKET: { ...S.PACKET, DECRYPTED: false },
      SHARDS: PACKET_SHARDS.map((SH) => ({ ...SH })),
    }));
    APPEND_AUDIT("Aarav Sharma", "STATUS_RESTORED", "Marked living — execution rolled back");
    PUSH_TOAST("Status restored to living — estate re-armed & fully revocable");
  }, [PATCH, APPEND_AUDIT, PUSH_TOAST]);

  // ================= LEGACY PACKET =================
  const RELEASE_SHARD = useCallback((SHARD_ID) => {
    PATCH((S) => ({ ...S, SHARDS: S.SHARDS.map((SH) => (SH.ID === SHARD_ID ? { ...SH, RELEASED: true } : SH)) }));
    APPEND_AUDIT("Trustee", "SHARD_RELEASED", SHARD_ID);
    PUSH_TOAST("Key shard released");
  }, [PATCH, APPEND_AUDIT, PUSH_TOAST]);

  const SET_PACKET_DECRYPTED = useCallback(() => {
    PATCH((S) => ({ ...S, PACKET: { ...S.PACKET, DECRYPTED: true } }));
    APPEND_AUDIT("Beneficiary", "PACKET_DECRYPTED", "Legacy Packet");
  }, [PATCH, APPEND_AUDIT]);

  // ================= E-SIGNATURE =================
  const SIGN_DOCUMENT = useCallback((DOC_ID, SIGNATURE_DATA) => {
    let NAME = "";
    SET_STORE((S) => {
      const DOC = S.DOCUMENTS.find((D) => D.ID === DOC_ID);
      NAME = DOC ? DOC.NAME : "";
      return { ...S, DOCUMENTS: S.DOCUMENTS.map((D) => (D.ID === DOC_ID ? { ...D, STATUS: "SIGNED", SIGNATURE: SIGNATURE_DATA } : D)) };
    });
    APPEND_AUDIT("Aarav Sharma", "DOCUMENT_SIGNED", NAME);
    PUSH_TOAST(`Signature affixed to ${NAME}`);
  }, [APPEND_AUDIT, PUSH_TOAST]);

  const NOTARIZE_DOCUMENT = useCallback((DOC_ID) => {
    let NAME = "";
    SET_STORE((S) => {
      const DOC = S.DOCUMENTS.find((D) => D.ID === DOC_ID);
      NAME = DOC ? DOC.NAME : "";
      return { ...S, DOCUMENTS: S.DOCUMENTS.map((D) => (D.ID === DOC_ID ? { ...D, NOTARIZED: true } : D)) };
    });
    APPEND_AUDIT("Adv. Meera Iyer", "DOCUMENT_NOTARIZED", NAME);
    PUSH_TOAST("Notary seal applied · RON session recorded");
  }, [APPEND_AUDIT, PUSH_TOAST]);

  // ================= WHITE-LABEL =================
  const PUBLISH_BRAND = useCallback((NAME, ACCENT, DOMAIN, TENANT_ID) => {
    PATCH((S) => ({
      ...S,
      BRAND: { NAME, ACCENT },
      TENANT_CONFIG: { ...S.TENANT_CONFIG, [TENANT_ID]: { NAME, ACCENT, DOMAIN } },
    }));
    APPEND_AUDIT("Aarav Sharma", "WHITELABEL_PUBLISHED", `${NAME} · ${DOMAIN}`);
    PUSH_TOAST(`${NAME} theme published live to ${DOMAIN}`);
  }, [PATCH, APPEND_AUDIT, PUSH_TOAST]);

  const RESET_BRAND = useCallback(() => {
    PATCH((S) => ({ ...S, BRAND: { NAME: null, ACCENT: null } }));
    PUSH_TOAST("Reverted to Legacy Ledger default theme");
  }, [PATCH, PUSH_TOAST]);

  const PROVISION_TENANT = useCallback((NAME) => {
    const ACCENTS = ["#2f8fff", "#57e389", "#ff7597", "#ffb86b", "#9d7bff"];
    PATCH((S) => {
      const T = {
        ID: `TN_${Date.now()}`,
        NAME,
        PLAN: "Trial",
        SEATS: 50,
        MAU: "0",
        STATUS: "PROVISIONING",
        ACCENT: ACCENTS[S.TENANTS.length % ACCENTS.length],
        BRAND: NAME.split(" ")[0],
      };
      return { ...S, TENANTS: [...S.TENANTS, T] };
    });
    APPEND_AUDIT("Aarav Sharma", "TENANT_PROVISIONED", NAME);
    PUSH_TOAST(`${NAME} provisioned`);
  }, [PATCH, APPEND_AUDIT, PUSH_TOAST]);

  // ================= BILLING =================
  const PAY_PLAN = useCallback((PLAN, CYCLE, AMOUNT_LABEL) => {
    PATCH((S) => {
      const INV = {
        ID: `INV_${Date.now()}`,
        NUMBER: `INV-2026-${String(S.BILLING.HISTORY.length + 8).padStart(4, "0")}`,
        DATE: new Date().toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" }),
        AMOUNT: AMOUNT_LABEL,
        STATUS: "PAID",
      };
      return {
        ...S,
        BILLING: { ...S.BILLING, PLAN_ID: PLAN.ID, CYCLE, ACTIVE_PLAN: PLAN.ID, HISTORY: [INV, ...S.BILLING.HISTORY] },
      };
    });
    APPEND_AUDIT("Aarav Sharma", "SUBSCRIPTION_PAID", `${PLAN.NAME} · ${AMOUNT_LABEL}`);
    PUSH_TOAST(`${PLAN.NAME} plan active — invoice issued`);
  }, [PATCH, APPEND_AUDIT, PUSH_TOAST]);

  // ================= LIVE ENGINE (FastAPI backend, backend/app.py) =================
  const [BACKEND, SET_BACKEND] = useState({
    ONLINE: false,
    CHECKED: false,
    VERSION: null,
    CASE_ID: "case_legacyledger_2026",
    SYNCING: false,
    WORKFLOWS: [],
    VERIFICATION: null,
    LAST_ERROR: null,
  });

  const PING_ENGINE = useCallback(async () => {
    try {
      const H = await ENGINE_API.HEALTH();
      SET_BACKEND((B) => ({ ...B, ONLINE: true, CHECKED: true, VERSION: H.version, LAST_ERROR: null }));
      return true;
    } catch (ERR) {
      SET_BACKEND((B) => ({ ...B, ONLINE: false, CHECKED: true, LAST_ERROR: ERR.message }));
      return false;
    }
  }, []);

  // Poll the engine's health so the badge reflects reality even if it starts late.
  useEffect(() => {
    PING_ENGINE();
    const TIMER = setInterval(PING_ENGINE, 15000);
    return () => clearInterval(TIMER);
  }, [PING_ENGINE]);

  // Push every classified asset into the Layer-1 engine, then read the graph back.
  const SYNC_TO_ENGINE = useCallback(async () => {
    const S = STORE_REF.current;
    const ASSETS = S.ASSETS.filter((A) => !A.IS_ROOT);
    SET_BACKEND((B) => ({ ...B, SYNCING: true }));
    let OK = 0;
    let FAIL = 0;
    for (const A of ASSETS) {
      try {
        await ENGINE_API.ENROLL_ASSET(ASSET_TO_ENROLLMENT(A, S.INTENTS[A.ID]));
        OK += 1;
      } catch (ERR) {
        // 409 = already enrolled — count as success for idempotency.
        if (/already|409|exist/i.test(ERR.message)) OK += 1;
        else FAIL += 1;
      }
    }
    SET_BACKEND((B) => ({ ...B, SYNCING: false }));
    APPEND_AUDIT("Aarav Sharma", "ENGINE_ASSET_SYNC", `${OK} assets → Layer 1 engine`);
    PUSH_TOAST(FAIL ? `Synced ${OK} assets (${FAIL} failed)` : `${OK} assets enrolled in the Layer-1 engine`, FAIL ? "warn" : "ok");
    return { OK, FAIL };
  }, [APPEND_AUDIT, PUSH_TOAST]);

  const REFRESH_WORKFLOWS = useCallback(async () => {
    const CID = BACKEND.CASE_ID;
    try {
      const WFS = await ENGINE_API.WORKFLOWS(CID);
      SET_BACKEND((B) => ({ ...B, WORKFLOWS: WFS }));
      return WFS;
    } catch (ERR) {
      SET_BACKEND((B) => ({ ...B, LAST_ERROR: ERR.message }));
      return [];
    }
  }, [BACKEND.CASE_ID]);

  // Full fiduciary pipeline: verify death (registry + attestation) then execute.
  const RUN_ENGINE_PIPELINE = useCallback(async () => {
    const S = STORE_REF.current;
    const CID = BACKEND.CASE_ID;
    const NAME = S.PROFILE.FULL_NAME || "Principal";
    const CONTACT = (S.BENEFICIARIES[0] && S.BENEFICIARIES[0].NAME) || "executor";
    SET_BACKEND((B) => ({ ...B, SYNCING: true }));
    try {
      // Ensure the engine has assets to act on first.
      await SYNC_TO_ENGINE();
      await ENGINE_API.REGISTRY_HIT(CID, NAME, `DC-2026-${Math.floor(1000 + Math.random() * 8999)}`);
      const VER = await ENGINE_API.ATTESTATION(CID, CONTACT);
      const WFS = await ENGINE_API.EXECUTE(CID, true);
      SET_BACKEND((B) => ({ ...B, SYNCING: false, VERIFICATION: VER, WORKFLOWS: WFS }));
      APPEND_AUDIT("Consensus Engine", "EXECUTION_STARTED", `${WFS.length} workflows · case ${CID}`);
      PUSH_TOAST(`Engine verified consensus & dispatched ${WFS.length} workflows`);
      return WFS;
    } catch (ERR) {
      SET_BACKEND((B) => ({ ...B, SYNCING: false, LAST_ERROR: ERR.message }));
      PUSH_TOAST(`Engine pipeline failed: ${ERR.message}`, "warn");
      return [];
    }
  }, [BACKEND.CASE_ID, SYNC_TO_ENGINE, APPEND_AUDIT, PUSH_TOAST]);

  const ENGINE_CHECKPOINT = useCallback(async (WORKFLOW_ID, APPROVED = true) => {
    try {
      await ENGINE_API.CHECKPOINT(WORKFLOW_ID, APPROVED);
      await REFRESH_WORKFLOWS();
      APPEND_AUDIT("Executor", APPROVED ? "CHECKPOINT_APPROVED" : "CHECKPOINT_REJECTED", WORKFLOW_ID);
      PUSH_TOAST(APPROVED ? "Checkpoint approved — workflow released" : "Checkpoint rejected");
    } catch (ERR) {
      PUSH_TOAST(`Checkpoint failed: ${ERR.message}`, "warn");
    }
  }, [REFRESH_WORKFLOWS, APPEND_AUDIT, PUSH_TOAST]);

  const ENGINE_ADVANCE = useCallback(async (WORKFLOW_ID) => {
    try {
      const WF = await ENGINE_API.ADVANCE(WORKFLOW_ID);
      await REFRESH_WORKFLOWS();
      PUSH_TOAST(`Workflow ${WF.executionstate}`);
    } catch (ERR) {
      PUSH_TOAST(`Advance failed: ${ERR.message}`, "warn");
    }
  }, [REFRESH_WORKFLOWS, PUSH_TOAST]);

  const RESET_ESTATE = useCallback(() => {
    try {
      localStorage.removeItem(STORAGE_KEY);
      localStorage.removeItem(STORAGE_KEY_SIGS);
      localStorage.removeItem(STORAGE_KEY_LEGACY);
    } catch { /* noop */ }
    SET_STORE(BUILD_DEFAULT_STATE());
    PUSH_TOAST("Estate reset to defaults");
  }, [PUSH_TOAST]);

  const VALUE = useMemo(
    () => ({
      STORE,
      TOASTS,
      PUSH_TOAST,
      APPEND_AUDIT,
      SET_PROFILE_FIELD,
      SAVE_PROFILE,
      UPDATE_SHARE,
      ADD_BENEFICIARY,
      REMOVE_BENEFICIARY,
      ASSIGN_INTENT,
      SET_INTENT_META,
      AUTO_CLASSIFY,
      LINK_BANK,
      TOGGLE_PROVIDER,
      RETRY_JOB,
      DISPATCH_QUEUED,
      RESOLVE_EXCEPTION,
      CHECK_IN,
      SIMULATE_TRIGGER,
      REPORT_DECEASED,
      RESTORE_LIVING,
      FILE_DEATH_CERTIFICATE,
      CONFIRM_DEATH_CERTIFICATE,
      ATTEST_TRUSTEE,
      ADVANCE_INACTIVITY,
      RESET_ACTIVATION_CASES,
      RELEASE_SHARD,
      SET_PACKET_DECRYPTED,
      SIGN_DOCUMENT,
      NOTARIZE_DOCUMENT,
      PUBLISH_BRAND,
      RESET_BRAND,
      PROVISION_TENANT,
      PAY_PLAN,
      RESET_ESTATE,
      BACKEND,
      PING_ENGINE,
      SYNC_TO_ENGINE,
      RUN_ENGINE_PIPELINE,
      REFRESH_WORKFLOWS,
      ENGINE_CHECKPOINT,
      ENGINE_ADVANCE,
    }),
    [STORE, TOASTS, PUSH_TOAST, APPEND_AUDIT, SET_PROFILE_FIELD, SAVE_PROFILE, UPDATE_SHARE, ADD_BENEFICIARY, REMOVE_BENEFICIARY, ASSIGN_INTENT, SET_INTENT_META, AUTO_CLASSIFY, LINK_BANK, TOGGLE_PROVIDER, RETRY_JOB, DISPATCH_QUEUED, RESOLVE_EXCEPTION, CHECK_IN, SIMULATE_TRIGGER, REPORT_DECEASED, RESTORE_LIVING, FILE_DEATH_CERTIFICATE, CONFIRM_DEATH_CERTIFICATE, ATTEST_TRUSTEE, ADVANCE_INACTIVITY, RESET_ACTIVATION_CASES, RELEASE_SHARD, SET_PACKET_DECRYPTED, SIGN_DOCUMENT, NOTARIZE_DOCUMENT, PUBLISH_BRAND, RESET_BRAND, PROVISION_TENANT, PAY_PLAN, RESET_ESTATE, BACKEND, PING_ENGINE, SYNC_TO_ENGINE, RUN_ENGINE_PIPELINE, REFRESH_WORKFLOWS, ENGINE_CHECKPOINT, ENGINE_ADVANCE]
  );

  return <EstateContext.Provider value={VALUE}>{children}</EstateContext.Provider>;
}

export function useEstate() {
  const CTX = useContext(EstateContext);
  if (!CTX) throw new Error("useEstate must be used within EstateProvider");
  return CTX;
}

// Trigger a real browser download of `CONTENT` as `FILENAME`.
export function DOWNLOAD_FILE(FILENAME, CONTENT, MIME = "text/plain") {
  const BLOB = new Blob([CONTENT], { type: MIME });
  const URL = window.URL.createObjectURL(BLOB);
  const A = document.createElement("a");
  A.href = URL;
  A.download = FILENAME;
  document.body.appendChild(A);
  A.click();
  A.remove();
  window.URL.revokeObjectURL(URL);
}


