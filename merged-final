          <IconCheck SIZE={16} /> Smart auto-classify
        </button>
      </div>

      <div className="intent-board">
        <div className="asset-queue scroll-slim">
          {ASSIGNABLE.map((N) => {
            const INTENT = INTENTS[N.ID] && INTENTS[N.ID].INTENT ? INTENT_TYPES[INTENTS[N.ID].INTENT] : null;
            return (
              <button
