  BILLING_HISTORY,
} from "./data.js";

// ==================================================================
// LEGACY LEDGER CO. · ESTATE STORE
// A single persistent source of truth. Every action a user takes
// genuinely mutates this state, persists to localStorage, and
// cascades across views (intents spawn pipeline jobs, links add
// assets, signatures & payments write to the immutable audit trail).
// ==================================================================

const STORAGE_KEY = "LEGACY_LEDGER_ESTATE_V2";
const STORAGE_KEY_LEGACY = "LEGACY_LEDGER_ESTATE_V1";
const STORAGE_KEY_SIGS = "LEGACY_LEDGER_SIGNATURES_V2";

function EXTRACT_SIGNATURES(STORE) {
  const TRIGGERS = (STORE.ACTIVATION && STORE.ACTIVATION.TRIGGERS) || BUILD_DEFAULT_TRIGGERS();
  return {
    DEATH_CERTIFICATE: (TRIGGERS.DEATH_CERTIFICATE && TRIGGERS.DEATH_CERTIFICATE.SIGNATURES) || {},
    TRUSTEE_QUORUM: (TRIGGERS.TRUSTEE_QUORUM && TRIGGERS.TRUSTEE_QUORUM.SIGNATURES) || {},
    WITNESS: (STORE.ACTIVATION && STORE.ACTIVATION.DEATH_RECORD && STORE.ACTIVATION.DEATH_RECORD.WITNESS_SIGNATURES) || [],
  };
}

function STRIP_SIGNATURE_DATA(STORE) {
  const TRIGGERS = STORE.ACTIVATION.TRIGGERS || BUILD_DEFAULT_TRIGGERS();
  const META = (SIGS) =>
    Object.fromEntries(
      Object.entries(SIGS || {}).map(([ID, SIG]) => [
        ID,
        { NAME: SIG.NAME, ROLE: SIG.ROLE, PURPOSE: SIG.PURPOSE, SIGNED_AT: SIG.SIGNED_AT, HAS_DATA: !!SIG.DATA },
      ])
    );
  return {
    ...STORE,
    ACTIVATION: {
      ...STORE.ACTIVATION,
      TRIGGERS: {
        ...TRIGGERS,
        DEATH_CERTIFICATE: {
          ...TRIGGERS.DEATH_CERTIFICATE,
          SIGNATURES: META(TRIGGERS.DEATH_CERTIFICATE.SIGNATURES),
        },
        TRUSTEE_QUORUM: {
          ...TRIGGERS.TRUSTEE_QUORUM,
          SIGNATURES: META(TRIGGERS.TRUSTEE_QUORUM.SIGNATURES),
        },
      },
      DEATH_RECORD: STORE.ACTIVATION.DEATH_RECORD
        ? {
            ...STORE.ACTIVATION.DEATH_RECORD,
            WITNESS_SIGNATURES: (STORE.ACTIVATION.DEATH_RECORD.WITNESS_SIGNATURES || []).map((W) => ({
              NAME: W.NAME,
              ROLE: W.ROLE,
              PURPOSE: W.PURPOSE,
              SIGNED_AT: W.SIGNED_AT,
              HAS_DATA: !!W.DATA,
            })),
          }
        : null,
    },
  };
}

function REHYDRATE_SIGNATURES(STORE, PACK) {
  if (!PACK) return STORE;
  const TRIGGERS = STORE.ACTIVATION.TRIGGERS || BUILD_DEFAULT_TRIGGERS();
  const MERGE_MAP = (META, FULL) => {
    const OUT = {};
    Object.keys({ ...(META || {}), ...(FULL || {}) }).forEach((ID) => {
      OUT[ID] = { ...(META && META[ID]), ...(FULL && FULL[ID]) };
    });
    return OUT;
  };
  return {
    ...STORE,
    ACTIVATION: {
      ...STORE.ACTIVATION,
      TRIGGERS: {
        ...TRIGGERS,
        DEATH_CERTIFICATE: {
          ...TRIGGERS.DEATH_CERTIFICATE,
          SIGNATURES: MERGE_MAP(TRIGGERS.DEATH_CERTIFICATE.SIGNATURES, PACK.DEATH_CERTIFICATE),
        },
        TRUSTEE_QUORUM: {
          ...TRIGGERS.TRUSTEE_QUORUM,
          SIGNATURES: MERGE_MAP(TRIGGERS.TRUSTEE_QUORUM.SIGNATURES, PACK.TRUSTEE_QUORUM),
        },
      },
      DEATH_RECORD: STORE.ACTIVATION.DEATH_RECORD
        ? {
            ...STORE.ACTIVATION.DEATH_RECORD,
            WITNESS_SIGNATURES:
              (PACK.WITNESS && PACK.WITNESS.length
                ? PACK.WITNESS
                : STORE.ACTIVATION.DEATH_RECORD.WITNESS_SIGNATURES) || [],
          }
        : null,
    },
  };
}

function BUILD_DEFAULT_TRIGGERS() {
  return {
    DEATH_CERTIFICATE: {
      FILED: false,
      CERTIFICATE_ID: null,
