          >
            <div style={{ display: "flex", alignItems: "center", gap: 12, marginBottom: 6 }}>
              <span className="dot" style={{ background: CATEGORY_COLOR(SELECTED.CATEGORY), width: 12, height: 12 }} />
              <div>
                <div className="node-title">{SELECTED.NAME}</div>
                <div className="ac-type">{ASSET_CATEGORIES[SELECTED.CATEGORY].LABEL} · {SELECTED.PROVIDER} · {SELECTED.VALUE}</div>
              </div>
            </div>

