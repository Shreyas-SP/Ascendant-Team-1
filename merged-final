        </p>
      </div>

      <div className="workflow-layout">
        <div>
          <div className="panel" style={{ overflow: "hidden", marginBottom: 16 }}>
            <div style={{ height: 240 }}>
              <Canvas camera={{ position: [0, 0, 7], fov: 55 }} dpr={[1, 2]}>
                <color attach="background" args={["#070812"]} />
                <ChainScene COLOR={FORMAT.COLOR} BLOCKS={Math.min(10, AUDIT_EVENTS.length)} />
              </Canvas>
            </div>
          </div>

          <div className="panel panel-pad">
