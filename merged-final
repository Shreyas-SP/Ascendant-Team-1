function HeartbeatOrb({ HUE = "#57e389" }) {
  const GROUP_REF = useRef();
  const CORE_REF = useRef();
  const RING_REFS = useRef([]);

  const DOTS = useMemo(() => new THREE.IcosahedronGeometry(1.5, 6).attributes.position.array, []);
  const COUNT = DOTS.length / 3;

  useFrame((STATE, DELTA) => {
    const T = STATE.clock.elapsedTime;
    const BEAT = T % 1.4;
    let PULSE = 0;
    if (BEAT < 0.12) PULSE = Math.sin((BEAT / 0.12) * Math.PI) * 0.16;
    else if (BEAT > 0.2 && BEAT < 0.32) PULSE = Math.sin(((BEAT - 0.2) / 0.12) * Math.PI) * 0.1;
    GROUP_REF.current.scale.setScalar(1 + PULSE);
    GROUP_REF.current.rotation.y += DELTA * 0.25;
    CORE_REF.current.material.opacity = 0.3 + PULSE * 2;

    RING_REFS.current.forEach((R, I) => {
      if (!R) return;
      const PHASE = (T * 0.5 + I * 0.5) % 1.5;
      const S = 1.4 + PHASE * 2.4;
      R.scale.setScalar(S);
      R.material.opacity = Math.max(0, 0.4 - PHASE * 0.3);
    });
  });

  return (
    <group ref={GROUP_REF}>
      <points>
        <bufferGeometry>
          <bufferAttribute attach="attributes-position" count={COUNT} array={DOTS} itemSize={3} />
        </bufferGeometry>
        <pointsMaterial color={HUE} size={0.035} sizeAttenuation transparent opacity={0.95} blending={THREE.AdditiveBlending} depthWrite={false} />
      </points>
      <mesh ref={CORE_REF}>
        <sphereGeometry args={[0.9, 32, 32]} />
        <meshBasicMaterial color={HUE} transparent opacity={0.3} />
      </mesh>
      {[0, 1, 2].map((I) => (
        <mesh key={I} ref={(EL) => (RING_REFS.current[I] = EL)} rotation={[Math.PI / 2, 0, 0]}>
          <torusGeometry args={[1.5, 0.015, 16, 64]} />
          <meshBasicMaterial color={HUE} transparent opacity={0.3} />
        </mesh>
      ))}
    </group>
  );
}

