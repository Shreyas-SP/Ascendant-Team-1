  const SELECTED = ASSIGNABLE.find((N) => N.ID === SELECTED_ID) || ASSIGNABLE[0];
  const CURRENT = INTENTS[SELECTED_ID] || {};
  const CURRENT_INTENT = CURRENT.INTENT || null;
  const DONE_COUNT = ASSIGNABLE.filter((N) => INTENTS[N.ID] && INTENTS[N.ID].INTENT).length;
  const PCT = Math.round((DONE_COUNT / ASSIGNABLE.length) * 100);

  const HANDLE_ASSIGN = (INTENT_ID) => {
    ASSIGN_INTENT(SELECTED_ID, INTENT_ID);
    PUSH_TOAST(`${SELECTED.NAME} → ${INTENT_TYPES[INTENT_ID].LABEL} · job queued`);
