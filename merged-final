import React, { useEffect, useMemo, useRef, useState } from "react";
import { Canvas, useFrame } from "@react-three/fiber";
import * as THREE from "three";
import { motion, AnimatePresence } from "framer-motion";
import { useEstate } from "../lib/store.jsx";
import ActivationCasesPanel from "./ActivationCasesPanel.jsx";
import { IconShield, IconPlus, IconCheck } from "./Icons.jsx";

// ----- Estate Readiness Sphere -------------------------------------------
// A fibonacci sphere of dots. The fraction of dots that light up (warm teal →
// violet) equals your live estate-readiness score — so the orb literally
// fills in as you seal your identity, allocate beneficiaries, classify
// assets, link accounts and sign documents. Dim dots are what's left to do.
const ORB_COUNT = 900;
const C_LO = new THREE.Color("#64e9d0");
const C_HI = new THREE.Color("#9d7bff");
const C_DIM = new THREE.Color("#262c49");

function ReadinessOrb({ READINESS }) {
  const GROUP_REF = useRef();
  const POINTS_REF = useRef();
  const CORE_REF = useRef();
  const HALO_REF = useRef();

  const POSITIONS = useMemo(() => {
    const ARR = new Float32Array(ORB_COUNT * 3);
    const R = 1.5;
    const GA = Math.PI * (3 - Math.sqrt(5));
    for (let I = 0; I < ORB_COUNT; I++) {
      const Y = 1 - (I / (ORB_COUNT - 1)) * 2;
      const RAD = Math.sqrt(1 - Y * Y);
      const TH = GA * I;
      ARR[I * 3] = Math.cos(TH) * RAD * R;
      ARR[I * 3 + 1] = Y * R;
      ARR[I * 3 + 2] = Math.sin(TH) * RAD * R;
    }
    return ARR;
  }, []);

  const COLORS = useMemo(() => new Float32Array(ORB_COUNT * 3), []);
  const TMP = useMemo(() => new THREE.Color(), []);

  const PAINT = (READY) => {
    const ACTIVE = Math.round(THREE.MathUtils.clamp(READY, 0, 1) * ORB_COUNT);
    for (let I = 0; I < ORB_COUNT; I++) {
      if (I < ACTIVE) TMP.copy(C_LO).lerp(C_HI, I / ORB_COUNT);
      else TMP.copy(C_DIM);
      COLORS[I * 3] = TMP.r;
      COLORS[I * 3 + 1] = TMP.g;
      COLORS[I * 3 + 2] = TMP.b;
    }
  };

  // Initial paint so first frame is correct, then repaint on every change.
  useMemo(() => PAINT(READINESS), []); // eslint-disable-line react-hooks/exhaustive-deps
  useEffect(() => {
    PAINT(READINESS);
    if (POINTS_REF.current) POINTS_REF.current.geometry.attributes.color.needsUpdate = true;
  }, [READINESS]); // eslint-disable-line react-hooks/exhaustive-deps

  useFrame((STATE, DELTA) => {
    const T = STATE.clock.elapsedTime;
    GROUP_REF.current.rotation.y += DELTA * 0.16;
    GROUP_REF.current.rotation.x = Math.sin(T * 0.3) * 0.14;
    const PULSE = 1 + Math.sin(T * 1.6) * 0.05;
    // The inner core swells as readiness climbs — a filling vault.
    CORE_REF.current.scale.setScalar((0.32 + READINESS * 0.64) * PULSE);
    CORE_REF.current.material.opacity = 0.1 + READINESS * 0.3;
    HALO_REF.current.scale.setScalar(1 + Math.sin(T * 1.1) * 0.04);
  });

  return (
    <group ref={GROUP_REF}>
      <points ref={POINTS_REF}>
        <bufferGeometry>
          <bufferAttribute attach="attributes-position" count={ORB_COUNT} array={POSITIONS} itemSize={3} />
          <bufferAttribute attach="attributes-color" count={ORB_COUNT} array={COLORS} itemSize={3} />
        </bufferGeometry>
        <pointsMaterial size={0.05} vertexColors sizeAttenuation transparent opacity={0.95} blending={THREE.AdditiveBlending} depthWrite={false} />
      </points>
      <mesh ref={CORE_REF}>
        <icosahedronGeometry args={[1, 2]} />
        <meshBasicMaterial color="#7c6cff" transparent opacity={0.2} />
      </mesh>
      <mesh ref={HALO_REF}>
        <sphereGeometry args={[1.5, 32, 32]} />
        <meshBasicMaterial color="#64e9d0" transparent opacity={0.045} blending={THREE.AdditiveBlending} depthWrite={false} />
      </mesh>
    </group>
  );
}

