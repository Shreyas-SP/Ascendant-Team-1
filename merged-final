import React, { useEffect, useMemo, useRef } from "react";
import { Canvas, useFrame } from "@react-three/fiber";
import { Billboard, Text } from "@react-three/drei";
import * as THREE from "three";
import { motion } from "framer-motion";
import { WORKFLOW_STATES, WORKFLOW_STAGES } from "../lib/data.js";
import { useEstate } from "../lib/store.jsx";
import { IconStream, IconCheck, IconSpark } from "./Icons.jsx";

const ACTION_COLORS = {
  CANCEL: "#ff7597",
  TRANSFER: "#7c6cff",
  MEMORIALIZE: "#64e9d0",
  ARCHIVE: "#ffb86b",
};

// Backend executionstate → colour + human label.
const ENGINE_STATE_META = {
  discovered: { COLOR: "#6b7099", LABEL: "Discovered" },
  pending_approval: { COLOR: "#ffb86b", LABEL: "Needs approval" },
  executing: { COLOR: "#7c6cff", LABEL: "Executing" },
  completed: { COLOR: "#57e389", LABEL: "Completed" },
};

const TIER_LABEL = {
  api_native: "API-native",
  browser_automation: "Browser bot",
  manual_packet: "Manual packet",
};

// ---------------- 3D PIPELINE ----------------
function StagePillar({ X, LABEL, INDEX }) {
  const REF = useRef();
  useFrame((STATE) => {
    const T = STATE.clock.elapsedTime;
    REF.current.material.emissiveIntensity = 0.6 + Math.sin(T * 1.5 + INDEX) * 0.25;
  });
  return (
    <group position={[X, 0, 0]}>
      <mesh ref={REF} rotation={[Math.PI / 2, 0, 0]}>
        <torusGeometry args={[1.1, 0.05, 16, 48]} />
        <meshStandardMaterial color="#7c6cff" emissive="#7c6cff" emissiveIntensity={0.7} />
      </mesh>
      <Billboard position={[0, 1.6, 0]}>
        <Text fontSize={0.24} color="#aeb4d8" anchorX="center">{LABEL}</Text>
      </Billboard>
    </group>
  );
}

function JobPacket({ OFFSET, COLOR, SPEED, LANE }) {
  const REF = useRef();
  const SPAN = 12;
  const START = -6;
  useFrame((STATE) => {
    const T = STATE.clock.elapsedTime;
    const P = (T * SPEED + OFFSET) % 1;
    REF.current.position.x = START + P * SPAN;
    REF.current.position.y = LANE + Math.sin(T * 2 + OFFSET * 10) * 0.12;
    REF.current.position.z = Math.cos(T * 1.4 + OFFSET * 8) * 0.5;
    const S = 0.9 + Math.sin(P * Math.PI) * 0.5;
    REF.current.scale.setScalar(0.14 * S);
    REF.current.material.opacity = Math.sin(P * Math.PI) * 0.9 + 0.1;
  });
  return (
    <mesh ref={REF}>
      <sphereGeometry args={[1, 16, 16]} />
      <meshBasicMaterial color={COLOR} transparent blending={THREE.AdditiveBlending} depthWrite={false} />
    </mesh>
  );
}

function FlowTube() {
  return (
    <mesh rotation={[0, 0, Math.PI / 2]}>
      <cylinderGeometry args={[0.02, 0.02, 12, 8]} />
      <meshBasicMaterial color="#7c6cff" transparent opacity={0.25} />
    </mesh>
  );
}

function PipelineScene({ PACKETS }) {
  const STAGE_X = useMemo(() => WORKFLOW_STAGES.map((_, I) => -5 + I * 2.5), []);
  return (
    <>
      <ambientLight intensity={0.6} />
      <pointLight position={[0, 5, 6]} intensity={1.1} />
      <FlowTube />
      {WORKFLOW_STAGES.map((S, I) => (
        <StagePillar key={S} X={STAGE_X[I]} LABEL={S} INDEX={I} />
      ))}
      {PACKETS.map((P, I) => (
        <JobPacket key={I} OFFSET={P.OFFSET} COLOR={P.COLOR} SPEED={P.SPEED} LANE={P.LANE} />
      ))}
    </>
  );
}

// ---------------- MAIN ----------------
export default function WorkflowStatusStream({ EXCEPTION_COUNT, ON_NAVIGATE }) {
  const {
    STORE,
    RETRY_JOB,
    DISPATCH_QUEUED,
    BACKEND,
    RUN_ENGINE_PIPELINE,
    REFRESH_WORKFLOWS,
    ENGINE_CHECKPOINT,
    ENGINE_ADVANCE,
  } = useEstate();
  const JOBS = STORE.JOBS;

  // Pull any existing workflows from the engine when it comes online.
  useEffect(() => {
    if (BACKEND.ONLINE) REFRESH_WORKFLOWS();
  }, [BACKEND.ONLINE, REFRESH_WORKFLOWS]);
  const PACKETS = useMemo(
    () =>
      Array.from({ length: 14 }).map((_, I) => ({
        OFFSET: Math.random(),
        SPEED: 0.05 + Math.random() * 0.06,
        LANE: (Math.random() - 0.5) * 1.4,
        COLOR: Object.values(ACTION_COLORS)[I % 4],
      })),
    []
  );

  const COUNT_BY = (STATE_ID) => JOBS.filter((J) => J.STATE === STATE_ID).length;
  const RUNNING = COUNT_BY("RUNNING");
  const DONE = COUNT_BY("SUCCESS");
  const OVERALL = Math.round(JOBS.reduce((S, J) => S + J.PROGRESS, 0) / JOBS.length);

  const RETRY = (ID) => RETRY_JOB(ID);

  return (
    <div className="view">
      <div className="view-head">
        <span className="eyebrow"><IconStream SIZE={14} /> Layer 3 · Execution Control</span>
        <h1 className="view-title">Automated Workflow Stream</h1>
        <p className="view-desc">
          The execution engine dispatches every mapped directive to a fleet of headless workers. Watch each
          cancellation, transfer and memorialization march through the pipeline in real time.
        </p>
      </div>

      <div className="kpi-strip">
        <div className="kpi"><div className="kpi-num" style={{ color: "var(--VIOLET-2)" }}>{RUNNING}</div><div className="kpi-lbl">Running now</div></div>
        <div className="kpi"><div className="kpi-num" style={{ color: "var(--GREEN)" }}>{DONE}</div><div className="kpi-lbl">Completed</div></div>
        <button className="kpi" style={{ textAlign: "left", cursor: "pointer" }} onClick={() => ON_NAVIGATE("EXCEPTIONS")}>
          <div className="kpi-num" style={{ color: "var(--AMBER)" }}>{EXCEPTION_COUNT}</div>
          <div className="kpi-lbl">Exceptions →</div>
        </button>
        <div className="kpi"><div className="kpi-num" style={{ color: "var(--TEAL)" }}>{OVERALL}%</div><div className="kpi-lbl">Overall progress</div></div>
      </div>

      <div className="workflow-layout">
        <div>
          <div className="pipeline-stage">
            <Canvas camera={{ position: [0, 1.5, 9], fov: 55 }} dpr={[1, 2]}>
              <color attach="background" args={["#070812"]} />
              <PipelineScene PACKETS={PACKETS} />
            </Canvas>
          </div>

          <div className="panel panel-pad">
            <div className="section-title" style={{ marginBottom: 16 }}>
              Active jobs
              <span className="live-pill" style={{ marginLeft: "auto" }}><span className="live-dot" /> Live</span>
            </div>
            {JOBS.map((J) => {
              const STATE = WORKFLOW_STATES[J.STATE];
              const A_COLOR = ACTION_COLORS[J.ACTION];
              return (
                <div className="job-row" key={J.ID}>
                  <div className="job-main">
                    <span className="action-tag" style={{ background: `${A_COLOR}22`, color: A_COLOR }}>{J.ACTION}</span>
                    <div>
                      <div className="job-name">{J.TARGET}</div>
                      <div className="job-sub">{J.PROVIDER} · stage {J.STAGE}/{WORKFLOW_STAGES.length} · {J.LATENCY}</div>
