import React, { useMemo, useState } from "react";
import { AnimatePresence, motion } from "framer-motion";
import Background3D from "./components/Background3D.jsx";
import NavRail from "./components/NavRail.jsx";
import ProfileInterface from "./components/ProfileInterface.jsx";
import AssetGraphExplorer from "./components/AssetGraphExplorer.jsx";
import IntentClassificationForms from "./components/IntentClassificationForms.jsx";
import ConnectAccounts from "./components/ConnectAccounts.jsx";
import ActivationMonitor from "./components/ActivationMonitor.jsx";
import WorkflowStatusStream from "./components/WorkflowStatusStream.jsx";
import ExceptionResolutionDashboard from "./components/ExceptionResolutionDashboard.jsx";
import HeadlessBrowserViewer from "./components/HeadlessBrowserViewer.jsx";
import LegacyPacketPortal from "./components/LegacyPacketPortal.jsx";
import AuditTrailFormatter from "./components/AuditTrailFormatter.jsx";
import ESignatureModule from "./components/ESignatureModule.jsx";
import WhiteLabelConsole from "./components/WhiteLabelConsole.jsx";
import BillingCheckout from "./components/BillingCheckout.jsx";
import { EstateProvider, useEstate } from "./lib/store.jsx";
import { EXCEPTION_QUEUE } from "./lib/data.js";
import { IconCheck } from "./components/Icons.jsx";

function AppShell() {
  const { STORE, TOASTS } = useEstate();
  const [ACTIVE_VIEW, SET_ACTIVE_VIEW] = useState("PROFILE");

  const EXCEPTION_COUNT = EXCEPTION_QUEUE.length - STORE.RESOLVED_EXCEPTIONS.length;

  const PROGRESS = useMemo(() => {
    const ASSIGNABLE = STORE.ASSETS.filter((N) => !N.IS_ROOT).length;
    const CLASSIFIED = Object.values(STORE.INTENTS).filter((I) => I && I.INTENT).length;
    const BASE = STORE.PROFILE.SAVED ? 25 : 12;
    return Math.min(100, Math.round(BASE + (CLASSIFIED / Math.max(1, ASSIGNABLE)) * 75));
  }, [STORE.ASSETS, STORE.INTENTS, STORE.PROFILE.SAVED]);

  const RENDER_VIEW = () => {
    switch (ACTIVE_VIEW) {
      case "PROFILE":
        return <ProfileInterface />;
      case "GRAPH":
        return <AssetGraphExplorer />;
      case "INTENT":
        return <IntentClassificationForms />;
      case "CONNECT":
        return <ConnectAccounts />;
      case "ACTIVATION":
        return <ActivationMonitor />;
      case "WORKFLOW":
        return <WorkflowStatusStream EXCEPTION_COUNT={EXCEPTION_COUNT} ON_NAVIGATE={SET_ACTIVE_VIEW} />;
      case "EXCEPTIONS":
        return <ExceptionResolutionDashboard />;
      case "HEADLESS":
        return <HeadlessBrowserViewer />;
      case "PACKET":
        return <LegacyPacketPortal />;
      case "AUDIT":
        return <AuditTrailFormatter />;
      case "ESIGN":
        return <ESignatureModule />;
      case "WHITELABEL":
        return <WhiteLabelConsole />;
      case "BILLING":
        return <BillingCheckout />;
      default:
        return null;
    }
  };

  return (
    <>
      <Background3D />
      <div className="bg-veil" />

      <div className="app-shell">
        <NavRail ACTIVE_VIEW={ACTIVE_VIEW} ON_NAVIGATE={SET_ACTIVE_VIEW} PROGRESS={PROGRESS} ALERT_COUNT={EXCEPTION_COUNT} />

        <main>
          <motion.div key={ACTIVE_VIEW} initial={{ opacity: 0, y: 12 }} animate={{ opacity: 1, y: 0 }} transition={{ duration: 0.32 }}>
            {RENDER_VIEW()}
          </motion.div>
        </main>
      </div>

      <div className="toast-stack">
        <AnimatePresence>
          {TOASTS.map((T) => (
            <motion.div
              key={T.ID}
              className="toast"
              initial={{ opacity: 0, x: 40 }}
              animate={{ opacity: 1, x: 0 }}
              exit={{ opacity: 0, x: 40 }}
            >
              <span className="dot" style={{ background: T.TONE === "warn" ? "var(--AMBER)" : "var(--GREEN)" }} />
              <IconCheck SIZE={16} />
              {T.MESSAGE}
            </motion.div>
          ))}
        </AnimatePresence>
      </div>
    </>
  );
}

export default function App() {
  return (
    <EstateProvider>
      <AppShell />
    </EstateProvider>
  );
}


