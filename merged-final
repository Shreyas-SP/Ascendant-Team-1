                <div className="link-list">
                  {CONNECTED.map((C) => (
                    <button className="link-row" key={C.ID} onClick={() => SELECT_NODE(C.ID)}>
                      <span className="dot" style={{ background: CATEGORY_COLOR(C.CATEGORY) }} />
                      {C.NAME}
                    </button>
                  ))}
                </div>
              </div>

              <button
                className={`btn ${ISOLATED ? "btn-ghost" : "btn-teal"}`}
                style={{ marginTop: "auto" }}
                onClick={() => {
                  const NEXT = !ISOLATED;
                  SET_ISOLATED(NEXT);
                  PUSH_TOAST(NEXT ? `Isolated ${SELECTED.NAME} + ${CONNECTED.length} linked` : "Showing full constellation");
                }}
              >
                <IconSpark SIZE={16} /> {ISOLATED ? "Show full graph" : "Isolate cluster"}
              </button>
            </>
          ) : (
            <div className="inspector-empty">
              <IconGraph SIZE={40} />
              <p>Click any glowing node in the constellation to inspect its details and connections.</p>
            </div>
          )}
        </motion.div>
      </div>
    </div>
  );
}


